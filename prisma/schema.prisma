// Customizable layout for the printed prescription ("paper"). Resolution is
// most-specific-wins: a row scoped to a profile (doctor) beats a branch row,
// which beats an organization row, which beats the global system default
// (organization_id/branch_id/profile_id all null, is_system = true). v1 ships
// only the seeded system default; the future template editor is CRUD over this
// table. `layout` is a PrescriptionTemplateLayout JSON (ordered blocks) — the
// frontend renders it through a block registry, so new blocks need no schema
// change. Scope columns are plain UUIDs (no FK) to keep this table additive.
model PrescriptionTemplate {
  id              String    @id @default(uuid()) @db.Uuid
  organization_id String?   @db.Uuid
  branch_id       String?   @db.Uuid
  profile_id      String?   @db.Uuid
  name            String
  is_system       Boolean   @default(false)
  layout          Json
  is_deleted      Boolean   @default(false)
  deleted_at      DateTime?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  @@index([organization_id])
  @@index([branch_id])
  @@index([profile_id])
  @@map("prescription_templates")
}

// Patient-history repeatable collections (allergies, pregnancies, family
// history, contraceptives, non-gyn surgeries, medications) were folded from
// their own relational tables into JSON-array columns on PatientObgynHistory —
// one history table per specialty. The id-keyed diff write + revision audit now
// operate over those JSON arrays. See @specialties/obgyn/patient-history.

model PatientHistoryNote {
  id              String         @id @default(uuid()) @db.Uuid
  patient_id      String         @db.Uuid
  patient         Patient        @relation(fields: [patient_id], references: [id], onDelete: Cascade)
  organization_id String         @db.Uuid
  organization    Organization   @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  author_id       String         @db.Uuid
  author          Profile        @relation("HistoryNoteAuthor", fields: [author_id], references: [id], onDelete: Cascade)
  section_code    String
  content         String
  visibility      NoteVisibility @default(PRIVATE_TO_ORG)
  is_deleted      Boolean        @default(false)
  deleted_at      DateTime?
  created_at      DateTime       @default(now())
  updated_at      DateTime       @updatedAt

  @@index([patient_id, section_code, created_at])
  @@index([patient_id, visibility, is_deleted])
  @@index([organization_id])
  @@index([author_id])
  @@map("patient_history_notes")
}

model PatientFieldFlag {
  id              String       @id @default(uuid()) @db.Uuid
  patient_id      String       @db.Uuid
  patient         Patient      @relation(fields: [patient_id], references: [id], onDelete: Cascade)
  organization_id String       @db.Uuid
  organization    Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  author_id       String       @db.Uuid
  author          Profile      @relation("FieldFlagAuthor", fields: [author_id], references: [id], onDelete: Cascade)
  section_code    String
  field_code      String
  note            String?      @db.Text
  is_deleted      Boolean      @default(false)
  deleted_at      DateTime?
  created_at      DateTime     @default(now())
  updated_at      DateTime     @updatedAt

  @@unique([patient_id, organization_id, section_code, field_code], name: "unique_flag_per_field")
  @@index([patient_id, organization_id, is_deleted])
  @@index([author_id])
  @@map("patient_field_flags")
}

