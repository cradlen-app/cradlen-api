model CarePath {
  id                  String            @id @default(uuid()) @db.Uuid
  specialty_id        String            @db.Uuid
  specialty           Specialty         @relation(fields: [specialty_id], references: [id], onDelete: Cascade)
  organization_id     String?           @db.Uuid
  organization        Organization?     @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  is_system           Boolean           @default(true)
  parent_id           String?           @db.Uuid
  parent              CarePath?         @relation("CarePathParent", fields: [parent_id], references: [id], onDelete: SetNull)
  children            CarePath[]        @relation("CarePathParent")
  // The journey template this care path resolves to at booking time. Each
  // care path maps 1:1 to a JourneyTemplate so the journey's type is
  // unambiguous (e.g. OBGYN_PREGNANCY ⇒ PREGNANCY template).
  journey_template_id String            @db.Uuid
  journey_template    JourneyTemplate   @relation(fields: [journey_template_id], references: [id], onDelete: Restrict)
  code                String
  name                String
  description         String?
  order               Int               @default(0)
  episodes            CarePathEpisode[]
  journeys            PatientJourney[]
  created_at          DateTime          @default(now())
  updated_at          DateTime          @updatedAt
  is_deleted          Boolean           @default(false)
  deleted_at          DateTime?

  @@unique([specialty_id, organization_id, code], map: "care_paths_scope_code_key")
  @@index([organization_id, specialty_id])
  @@index([journey_template_id])
  @@map("care_paths")
}

model CarePathEpisode {
  id              String           @id @default(uuid()) @db.Uuid
  care_path_id    String           @db.Uuid
  care_path       CarePath         @relation(fields: [care_path_id], references: [id], onDelete: Cascade)
  organization_id String?          @db.Uuid
  organization    Organization?    @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  is_system       Boolean          @default(true)
  code            String
  name            String
  order           Int              @default(0)
  episodes        PatientEpisode[]
  created_at      DateTime         @default(now())
  updated_at      DateTime         @updatedAt
  is_deleted      Boolean          @default(false)
  deleted_at      DateTime?

  @@unique([care_path_id, organization_id, code])
  @@index([organization_id])
  @@map("care_path_episodes")
}

// Maps a care path to the patient-history sections relevant to it. Drives which
// embedded `history_*` sections the OB/GYN examination surfaces once the doctor
// picks a care path (the rest of the full history stays out of the encounter).
// String-keyed by section_code (the FormSection.code in obgyn_examination) — no
// FK to FormSection so it is admin/seed editable.
model CarePathHistorySection {
  id             String    @id @default(uuid()) @db.Uuid
  specialty_code String
  care_path_code String
  section_code   String
  order          Int       @default(0)
  is_deleted     Boolean   @default(false)
  deleted_at     DateTime?
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt

  @@unique([specialty_code, care_path_code, section_code])
  @@index([specialty_code, care_path_code])
  @@map("care_path_history_sections")
}

// Declares the optional "journey clinical surface" for a care path: the form
// template that backs the patient's active-journey tab (e.g. the pregnancy
// profile + per-visit maternal/fetal surveillance). When a care path has a row
// here, the visit workspace renders one extra tab for the active journey; when
// it has none, no extra tab appears. String-keyed (no FK to FormTemplate), like
// CarePathHistorySection — admin/seed editable. One surface per care path.
model CarePathClinicalSurface {
  id             String    @id @default(uuid()) @db.Uuid
  specialty_code String
  care_path_code String
  template_code  String
  label          String
  order          Int       @default(0)
  is_deleted     Boolean   @default(false)
  deleted_at     DateTime?
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt

  @@unique([specialty_code, care_path_code])
  @@index([specialty_code, care_path_code])
  @@map("care_path_clinical_surfaces")
}

enum BloodGroupRh {
  A_POS
  A_NEG
  B_POS
  B_NEG
  AB_POS
  AB_NEG
  O_POS
