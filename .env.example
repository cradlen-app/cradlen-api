# =============================================================================
# Application
# =============================================================================
APP_NAME=cradlen-api
NODE_ENV=development
PORT=3000

# =============================================================================
# API
# =============================================================================
API_DEFAULT_VERSION=1

# =============================================================================
# Database (Neon PostgreSQL)
# Get these from your Neon dashboard -> Connection Details
# =============================================================================
DATABASE_URL=postgresql://<user>:<password>@<pooler-host>/<db>?sslmode=require&channel_binding=require
DIRECT_URL=postgresql://<user>:<password>@<direct-host>/<db>?sslmode=require&channel_binding=require

# =============================================================================
# Logging
# Values: trace | debug | info | warn | error | fatal
# =============================================================================
LOG_LEVEL=info

# =============================================================================
# CORS
# Comma-separated list of allowed origins. Leave empty to deny all.
# (The cradlen-admin dashboard does NOT need an entry here — it calls /v1/admin/*
# server-side via its own Next proxy, so the browser stays same-origin.)
# =============================================================================
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# =============================================================================
# Rate Limiting
# TTL in milliseconds, LIMIT = max requests per TTL window per IP
# =============================================================================
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# =============================================================================
# Localisation
# =============================================================================
DEFAULT_LOCALE=en
SUPPORTED_LOCALES=en,ar
FALLBACK_LOCALE=en

# =============================================================================
# Auth (JWT)
# =============================================================================
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars
JWT_RESET_SECRET=change_me_reset_secret_min_32_chars
# Access tokens are stateless (not revocable before expiry); 30m halves refresh
# churn vs 15m, which reduces refresh-rotation races. Keep this bounded.
JWT_ACCESS_EXPIRATION=30m
# Refresh token = sliding idle window. Each /auth/refresh issues a fresh 7d
# token, so a user active within any 7-day window stays signed in.
JWT_REFRESH_EXPIRATION=7d
JWT_REGISTRATION_EXPIRATION=30m
# TTL for the short-lived Socket.IO handshake ticket (POST /auth/ws-ticket)
JWT_WS_TICKET_EXPIRATION=60s

# =============================================================================
# Platform admin (cross-tenant operator dashboard)
# Bootstraps the first platform admin via `prisma db seed` (no self-signup).
# Re-seeding with a changed password rotates the credential. Admin tokens reuse
# the JWT_ACCESS/REFRESH secrets above, discriminated by a distinct token type.
# =============================================================================
PLATFORM_ADMIN_EMAIL=admin@cradlen.com
PLATFORM_ADMIN_PASSWORD=change_me_strong_admin_password
PLATFORM_ADMIN_NAME=Platform Admin
# Origin of the cradlen-admin dashboard. Used to build admin invite links
# (set-password) emailed when an admin adds another admin. Default: localhost:3100.
ADMIN_APP_URL=http://localhost:3100

# =============================================================================
# Email (Resend)
# Get API key from https://resend.com/api-keys
# =============================================================================
RESEND_API_KEY=re_xxxxxxxxxxxx
# Use your verified domain address in production.
# While Cloudflare DNS is unresolved, use onboarding@resend.dev (Resend sandbox sender — no domain verification needed).
RESEND_FROM_EMAIL=noreply@yourdomain.com
# Display name shown as the email sender (e.g. "Cradlen <noreply@…>"). Optional.
RESEND_FROM_NAME=Cradlen
# Inbox that receives in-app "Help us improve Cradlen" feedback submissions.
FEEDBACK_NOTIFY_EMAIL=cradlen.app@gmail.com

# =============================================================================
# Subscription
# =============================================================================
FREE_TRIAL_DAYS=14

# =============================================================================
# App URL
# =============================================================================
APP_URL=http://localhost:3000

# =============================================================================
# Invitations
# =============================================================================
INVITATION_EXPIRE_HOURS=72

# =============================================================================
# Object storage (Cloudflare R2 — S3-compatible)
# Get credentials from: Cloudflare dashboard → R2 → Manage API Tokens
# The bucket must be PRIVATE; the API issues short-lived presigned URLs.
# =============================================================================
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET=cradlen-attachments
# Optional — defaults to https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com
# R2_ENDPOINT=
# Optional tuning (defaults shown)
R2_PRESIGN_PUT_TTL_SECONDS=300
R2_PRESIGN_GET_TTL_SECONDS=120
R2_MAX_UPLOAD_BYTES=15000000
R2_ALLOWED_CONTENT_TYPES=application/pdf,image/png,image/jpeg,image/webp

# =============================================================================
# Subscription Payments (manual-proof providers)
# Settlement destinations shown to the owner in the payment instructions.
# =============================================================================
INSTAPAY_ADDRESS=clinic@instapay
WALLET_NUMBER=01000000000

# =============================================================================
# Sentry (Error Monitoring & Tracing)
# Get DSN from: Sentry dashboard → Project → Settings → Client Keys
# =============================================================================
SENTRY_DSN=https://<key>@<org>.ingest.de.sentry.io/<project-id>
