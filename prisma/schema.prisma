generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum RegistrationStatus {
  PENDING
  ACTIVE
}

enum OrganizationStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum BranchStatus {
  ACTIVE
  INACTIVE
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  EXPIRED
  CANCELLED
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  CANCELLED
}

enum DayOfWeek {
  MON
  TUE
  WED
  THU
  FRI
  SAT
  SUN
}

model SubscriptionPlan {
  id            String         @id @default(uuid()) @db.Uuid
  plan          String
  max_branches  Int
  max_staff     Int
  created_at    DateTime       @default(now())
  updated_at    DateTime       @updatedAt
  subscriptions Subscription[]

  @@unique([plan])
  @@map("subscription_plans")
}

model Organization {
  id            String             @id @default(uuid()) @db.Uuid
  name          String
  specialities  String[]
  status        OrganizationStatus
  is_deleted    Boolean            @default(false)
  deleted_at    DateTime?
  created_at    DateTime           @default(now())
  updated_at    DateTime           @updatedAt
  branches      Branch[]
  staff         Staff[]
  subscriptions Subscription[]
  invitations   StaffInvitation[]

  @@map("organizations")
}

model Branch {
  id                 String                  @id @default(uuid()) @db.Uuid
  address            String
  city               String
  governorate        String
  is_main            Boolean                 @default(false)
  status             BranchStatus
  is_deleted         Boolean                 @default(false)
  deleted_at         DateTime?
  created_at         DateTime                @default(now())
  updated_at         DateTime                @updatedAt
  organization_id    String                  @db.Uuid
  organization       Organization            @relation(fields: [organization_id], references: [id])
  staff              Staff[]
  invitationBranches StaffInvitationBranch[]

  @@unique([id, organization_id])
  @@map("branches")
}

model User {
  id                  String              @id @default(uuid()) @db.Uuid
  first_name          String
  last_name           String
  email               String              @unique
  phone_number        String?
  password_hashed     String
  is_active           Boolean             @default(true)
  is_deleted          Boolean             @default(false)
  deleted_at          DateTime?
  verified_at         DateTime?
  registration_status RegistrationStatus  @default(PENDING)
  created_at          DateTime            @default(now())
  updated_at          DateTime            @updatedAt
  profile             Profile?
  staff               Staff[]
  refreshTokens       RefreshToken[]
  emailVerifications  EmailVerification[]
  passwordResets      PasswordReset[]
  sentInvitations     StaffInvitation[]   @relation("InvitedBy")

  @@map("users")
}

model Role {
  id               String            @id @default(uuid()) @db.Uuid
  name             String            @unique
  created_at       DateTime          @default(now())
  updated_at       DateTime          @updatedAt
  staff            Staff[]
  staffInvitations StaffInvitation[]

  @@map("roles")
}

model Profile {
  id          String    @id @default(uuid()) @db.Uuid
  is_clinical Boolean   @default(false)
  speciality  String?
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
  is_deleted  Boolean   @default(false)
  deleted_at  DateTime?
  user_id     String    @unique @db.Uuid
  user        User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("profiles")
}

model Staff {
  id              String           @id @default(uuid()) @db.Uuid
  user_id         String           @db.Uuid
  organization_id String           @db.Uuid
  branch_id       String           @db.Uuid
  role_id         String           @db.Uuid
  job_title       String?
  specialty       String?
  created_at      DateTime         @default(now())
  updated_at      DateTime         @updatedAt
  is_deleted      Boolean          @default(false)
  deleted_at      DateTime?
  user            User             @relation(fields: [user_id], references: [id])
  organization    Organization     @relation(fields: [organization_id], references: [id])
  branch          Branch           @relation(fields: [branch_id, organization_id], references: [id, organization_id])
  role            Role             @relation(fields: [role_id], references: [id])
  schedule        WorkingSchedule?

  @@unique([user_id, organization_id, branch_id, role_id])
  @@map("staff")
}

model Subscription {
  id                   String             @id @default(uuid()) @db.Uuid
  organization_id      String             @db.Uuid
  subscription_plan_id String             @db.Uuid
  status               SubscriptionStatus @default(TRIAL)
  starts_at            DateTime           @default(now())
  ends_at              DateTime?
  trial_ends_at        DateTime?
  created_at           DateTime           @default(now())
  updated_at           DateTime           @updatedAt
  is_deleted           Boolean            @default(false)
  deleted_at           DateTime?
  organization         Organization       @relation(fields: [organization_id], references: [id])
  subscription_plan    SubscriptionPlan   @relation(fields: [subscription_plan_id], references: [id])

  @@map("subscriptions")
}

model RefreshToken {
  id         String    @id @default(uuid()) @db.Uuid
  jti        String    @unique @db.Uuid
  token_hash String
  user_id    String    @db.Uuid
  expires_at DateTime
  is_revoked Boolean   @default(false)
  revoked_at DateTime?
  created_at DateTime  @default(now())
  user       User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model EmailVerification {
  id         String    @id @default(uuid()) @db.Uuid
  user_id    String    @db.Uuid
  code_hash  String
  expires_at DateTime
  used_at    DateTime?
  created_at DateTime  @default(now())
  user       User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("email_verifications")
}

model PasswordReset {
  id         String    @id @default(uuid()) @db.Uuid
  user_id    String    @db.Uuid
  code_hash  String
  expires_at DateTime
  used_at    DateTime?
  created_at DateTime  @default(now())
  user       User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("password_resets")
}

model StaffInvitation {
  id              String           @id @default(uuid()) @db.Uuid
  organization_id String           @db.Uuid
  invited_by_id   String           @db.Uuid
  role_id         String           @db.Uuid
  email           String
  first_name      String
  last_name       String
  phone           String?
  job_title       String
  specialty       String?
  token_hash      String
  status          InvitationStatus @default(PENDING)
  expires_at      DateTime
  accepted_at     DateTime?
  is_deleted      Boolean          @default(false)
  deleted_at      DateTime?
  created_at      DateTime         @default(now())
  updated_at      DateTime         @updatedAt

  organization Organization            @relation(fields: [organization_id], references: [id])
  invited_by   User                    @relation("InvitedBy", fields: [invited_by_id], references: [id])
  role         Role                    @relation(fields: [role_id], references: [id])
  branches     StaffInvitationBranch[]

  @@index([organization_id, status])
  @@index([email])
  @@index([expires_at])
  @@map("staff_invitations")
}

model StaffInvitationBranch {
  id              String   @id @default(uuid()) @db.Uuid
  invitation_id   String   @db.Uuid
  branch_id       String   @db.Uuid
  organization_id String   @db.Uuid
  created_at      DateTime @default(now())

  invitation StaffInvitation  @relation(fields: [invitation_id], references: [id], onDelete: Cascade)
  branch     Branch           @relation(fields: [branch_id, organization_id], references: [id, organization_id])
  schedule   WorkingSchedule?

  @@index([invitation_id])
  @@map("staff_invitation_branches")
}

model WorkingSchedule {
  id                         String   @id @default(uuid()) @db.Uuid
  staff_invitation_branch_id String?  @unique @db.Uuid
  staff_id                   String?  @unique @db.Uuid
  created_at                 DateTime @default(now())
  updated_at                 DateTime @updatedAt

  invitation_branch StaffInvitationBranch? @relation(fields: [staff_invitation_branch_id], references: [id])
  staff             Staff?                 @relation(fields: [staff_id], references: [id])
  days              WorkingDay[]

  @@map("working_schedules")
}

model WorkingDay {
  id          String    @id @default(uuid()) @db.Uuid
  schedule_id String    @db.Uuid
  day_of_week DayOfWeek
  created_at  DateTime  @default(now())

  schedule WorkingSchedule @relation(fields: [schedule_id], references: [id], onDelete: Cascade)
  shifts   WorkingShift[]

  @@index([schedule_id])
  @@unique([schedule_id, day_of_week])
  @@map("working_days")
}

model WorkingShift {
  id         String   @id @default(uuid()) @db.Uuid
  day_id     String   @db.Uuid
  start_time String
  end_time   String
  created_at DateTime @default(now())

  day WorkingDay @relation(fields: [day_id], references: [id], onDelete: Cascade)

  @@index([day_id])
  @@map("working_shifts")
}
