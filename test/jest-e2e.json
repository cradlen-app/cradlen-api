{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..",
  "testMatch": ["<rootDir>/test/**/*.e2e-spec.ts"],
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^(\\.{1,2}/.*)\\.js$": "$1",
    "^@common/(.*?)(\\.js)?$": "<rootDir>/src/common/$1",
    "^@infrastructure/(.*?)(\\.js)?$": "<rootDir>/src/infrastructure/$1",
    "^@builder/(.*?)(\\.js)?$": "<rootDir>/src/builder/$1",
    "^@core/(.*?)(\\.js)?$": "<rootDir>/src/core/$1",
    "^@plugins/(.*?)(\\.js)?$": "<rootDir>/src/plugins/$1",
    "^@specialties/(.*?)(\\.js)?$": "<rootDir>/src/specialties/$1",
    "^@config/(.*?)(\\.js)?$": "<rootDir>/src/config/$1"
  },
  "testEnvironment": "node",
  "modulePathIgnorePatterns": ["<rootDir>/dist"],
  "testPathIgnorePatterns": ["<rootDir>/dist"],
  "globalSetup": "<rootDir>/test/helpers/global-setup.ts",
  "globalTeardown": "<rootDir>/test/helpers/global-teardown.ts",
  "testTimeout": 30000,
  "maxWorkers": 1,
  "forceExit": true,
  "clearMocks": true,
  "setupFiles": ["<rootDir>/test/helpers/setup-env.ts"]
}
