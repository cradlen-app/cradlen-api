// ============================================================================
// Builder DSL — form templates, sections, fields
// Authored in code via prisma/seed.ts; never admin-managed at runtime.
// ============================================================================

model FormTemplate {
  id                 String             @id @default(uuid()) @db.Uuid
  code               String
  name               String
  description        String?
  scope              FormScope
  version            Int                @default(1)
  status             FormTemplateStatus @default(DRAFT)
  published_at       DateTime?
  is_active          Boolean            @default(false)
  activated_at       DateTime?
  // Display-only templates render read-only in the frontend (no input controls)
  // and must never be a write target. Used by the OB/GYN patient-history surface.
  is_display_only    Boolean            @default(false)
  specialty_id       String?            @db.Uuid
  specialty          Specialty?         @relation(fields: [specialty_id], references: [id], onDelete: SetNull)
  parent_template_id String?            @db.Uuid
  parent_template    FormTemplate?      @relation("FormTemplateExtensions", fields: [parent_template_id], references: [id], onDelete: Cascade)
  extensions         FormTemplate[]     @relation("FormTemplateExtensions")
  extension_key      String?
  created_by_id      String?            @db.Uuid
  created_by         Profile?           @relation("FormTemplateCreatedBy", fields: [created_by_id], references: [id], onDelete: SetNull)
  updated_by_id      String?            @db.Uuid
  updated_by         Profile?           @relation("FormTemplateUpdatedBy", fields: [updated_by_id], references: [id], onDelete: SetNull)
  is_deleted         Boolean            @default(false)
  deleted_at         DateTime?
  created_at         DateTime           @default(now())
  updated_at         DateTime           @updatedAt
  sections           FormSection[]
  visits             Visit[]            @relation("VisitFormTemplate")
  medical_rep_visits MedicalRepVisit[]  @relation("MedicalRepVisitFormTemplate")

  @@unique([code, version])
  @@index([scope, status, is_deleted])
  @@index([parent_template_id, extension_key])
  // Partial unique indexes + symmetry CHECK added via raw-SQL block in the
  // migration (Prisma does not support partial unique indexes / CHECK constraints natively):
  //   form_templates_code_active_shell_unique     — one active shell per code
  //   form_templates_parent_ext_active_unique     — one active extension per (parent, key)
  //   form_templates_extension_symmetry_check     — (parent_template_id IS NULL) = (extension_key IS NULL)
  @@map("form_templates")
}

model FormSection {
  id               String       @id @default(uuid()) @db.Uuid
  form_template_id String       @db.Uuid
  form_template    FormTemplate @relation(fields: [form_template_id], references: [id], onDelete: Cascade)
  code             String
  name             String
  order            Int
  is_repeatable    Boolean      @default(false)
  config           Json         @default("{\"ui\":{},\"validation\":{},\"logic\":{}}")
  is_deleted       Boolean      @default(false)
  deleted_at       DateTime?
  created_at       DateTime     @default(now())
  updated_at       DateTime     @updatedAt
  fields           FormField[]

  @@unique([form_template_id, code])
  @@map("form_sections")
}

model FormField {
  id                String            @id @default(uuid()) @db.Uuid
  section_id        String            @db.Uuid
  section           FormSection       @relation(fields: [section_id], references: [id], onDelete: Cascade)
  code              String
  label             String
  type              FormFieldType
  order             Int
  required          Boolean           @default(false)
  binding_namespace BindingNamespace?
  binding_path      String?
  config            Json              @default("{\"ui\":{},\"validation\":{},\"logic\":{}}")
  is_deleted        Boolean           @default(false)
  deleted_at        DateTime?
  created_at        DateTime          @default(now())
  updated_at        DateTime          @updatedAt

  @@unique([section_id, code])
  @@map("form_fields")
}

