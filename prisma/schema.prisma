// ============================================================================
// UMR redesign — PR4
// Revision shadow tables. Append-only audit trail of prior snapshots for
// clinical mutable rows. Written inside the same transaction as the live-row
// update, so every PATCH and amendment leaves a verifiable history.
//
// Shape mirrors the table being shadowed:
//   <entity>_id  FK to the live row
//   version      the SNAPSHOT version (i.e. the version BEFORE the change)
//   snapshot     full prior row contents as JSON
//   changed_fields  list of fields that differ between snapshot and new state
//   revised_by_id   FK profile (who performed the mutation)
//   revised_at      timestamp
//   revision_reason optional free-text (mandatory for amendments)
// ============================================================================

model PatientObgynHistoryRevision {
  id              String              @id @default(uuid()) @db.Uuid
  entity_id       String              @db.Uuid
  entity          PatientObgynHistory @relation(fields: [entity_id], references: [id], onDelete: Cascade)
  version         Int
  snapshot        Json
  changed_fields  Json
  revised_by_id   String              @db.Uuid
  revised_by      Profile             @relation("PatientObgynHistoryRevisedBy", fields: [revised_by_id], references: [id], onDelete: Cascade)
  revised_at      DateTime            @default(now())
  revision_reason String?

  @@index([entity_id, version])
  @@map("patient_obgyn_history_revisions")
}

