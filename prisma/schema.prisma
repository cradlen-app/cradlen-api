  result_attachment_url String?
  result_source         InvestigationResultSource      @default(CLINIC)
  resulted_at           DateTime?
  resulted_by_id        String?                        @db.Uuid
  resulted_by           Profile?                       @relation("InvestigationResultedBy", fields: [resulted_by_id], references: [id], onDelete: SetNull)
  reviewed_at           DateTime?
  reviewed_by_id        String?                        @db.Uuid
  reviewed_by           Profile?                       @relation("InvestigationReviewedBy", fields: [reviewed_by_id], references: [id], onDelete: SetNull)
