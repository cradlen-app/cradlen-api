model Visit {
  id                  String                @id @default(uuid()) @db.Uuid
  episode_id          String                @db.Uuid
  episode             PatientEpisode        @relation(fields: [episode_id], references: [id], onDelete: Cascade)
  assigned_doctor_id  String                @db.Uuid
  assigned_doctor     Profile               @relation("DoctorVisits", fields: [assigned_doctor_id], references: [id], onDelete: Cascade)
  branch_id           String                @db.Uuid
  branch              Branch                @relation(fields: [branch_id], references: [id], onDelete: Cascade)
  created_by_id       String                @db.Uuid
  created_by          Profile               @relation("CreatedVisits", fields: [created_by_id], references: [id], onDelete: Cascade)
  appointment_type    AppointmentType
  priority            VisitPriority
  status              VisitStatus           @default(SCHEDULED)
  scheduled_at        DateTime
  checked_in_at       DateTime?
  started_at          DateTime?
  completed_at        DateTime?
  notes               String?
  queue_number        Int?
  follow_up_date      DateTime?
  follow_up_notes     String?
  // Single optimistic-concurrency token for the unified Examination tab
  // (PATCH /v1/visits/:id/examination). Bumped on every successful save.
  examination_version Int                   @default(1)
  // Specialty captured at booking. Drives the patient-history template
  // resolver on the frontend (e.g. "OBGYN" → obgyn_patient_history). Nullable
  // for pre-existing rows; new bookings always populate it.
  specialty_code      String?
  // Audit anchor: which form-template version this visit was booked from.
  // Never mutated on update — the original booking's contract is the legal
  // record. SetNull so deleting a template (rare) doesn't cascade visits.
  form_template_id    String?               @db.Uuid
  form_template       FormTemplate?         @relation("VisitFormTemplate", fields: [form_template_id], references: [id], onDelete: Restrict)
  vitals              VisitVitals?
  encounter           VisitEncounter?
  obgyn_encounter     VisitObgynEncounter?
  pregnancy_record    VisitPregnancyRecord?
  investigations      VisitInvestigation[]
  diagnoses           VisitDiagnosis[]
  prescription        Prescription?
  invoices            Invoice[]             @relation("VisitInvoices")
  created_at          DateTime              @default(now())
  updated_at          DateTime              @updatedAt
  is_deleted          Boolean               @default(false)
  deleted_at          DateTime?

  @@index([episode_id, is_deleted])
  @@index([branch_id, status, is_deleted])
  @@index([branch_id, scheduled_at])
  @@index([assigned_doctor_id, branch_id, checked_in_at, is_deleted])
  @@map("visits")
}

