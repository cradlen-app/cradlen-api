  service services [not null]
  created_by profiles

  indexes {
    (price_list_id, service_id) [unique]
  }
}

Table provider_services {
  id String [pk]
  profile_id String [not null]
  service_id String [not null]
  organization_id String [not null]
  branch_id String
  duration_minutes Int
  is_active Boolean [not null, default: true]
  is_deleted Boolean [not null, default: false]
  deleted_at DateTime
  created_by_id String
  created_at DateTime [default: `now()`, not null]
  updated_at DateTime [not null]
  profile profiles [not null]
  service services [not null]
  organization organizations [not null]
  branch branches
  created_by profiles

  indexes {
    (profile_id, service_id, organization_id, branch_id) [unique]
  }
}

Table provider_price_overrides {
  id String [pk]
  profile_id String [not null]
  service_id String [not null]
  organization_id String [not null]
  branch_id String
  price Decimal [not null]
  currency String [not null, default: 'EGP']
  valid_from DateTime
  valid_to DateTime
  is_active Boolean [not null, default: true]
  is_deleted Boolean [not null, default: false]
  deleted_at DateTime
  created_by_id String
  created_at DateTime [default: `now()`, not null]
  updated_at DateTime [not null]
  profile profiles [not null]
  service services [not null]
  organization organizations [not null]
  branch branches
  created_by profiles
}

Table invoice_sequences {
  id String [pk]
  organization_id String [not null]
  year Int [not null]
  last_seq Int [not null, default: 0]
  is_deleted Boolean [not null, default: false]
  deleted_at DateTime
  created_at DateTime [default: `now()`, not null]
  updated_at DateTime [not null]
  organization organizations [not null]

  indexes {
    (organization_id, year) [unique]
  }
}

Table invoices {
  id String [pk]
  invoice_number String [not null]
  invoice_type InvoiceType [not null, default: 'STANDARD']
  organization_id String [not null]
  branch_id String [not null]
  patient_id String [not null]
  visit_id String
  assigned_doctor_id String
  status InvoiceStatus [not null, default: 'DRAFT']
  subtotal Decimal [not null, default: 0]
  discount_amount Decimal [not null, default: 0]
  tax_amount Decimal [not null, default: 0]
  total_amount Decimal [not null, default: 0]
  paid_amount Decimal [not null, default: 0]
  currency String [not null, default: 'EGP']
  notes String
  issued_at DateTime
  due_date DateTime
  created_by_id String [not null]
  is_deleted Boolean [not null, default: false]
  deleted_at DateTime
  created_at DateTime [default: `now()`, not null]
  updated_at DateTime [not null]
  organization organizations [not null]
  branch branches [not null]
  patient patients [not null]
  visit visits
  assigned_doctor profiles
  created_by profiles [not null]
  items invoice_items [not null]
  payments payments [not null]
  insurance_claim invoice_insurance_claims

  indexes {
    (organization_id, invoice_number) [unique]
  }
}

Table invoice_items {
  id String [pk]
  invoice_id String [not null]
  service_id String
  description String [not null]
  quantity Int [not null, default: 1]
  unit_price Decimal [not null]
  currency String [not null, default: 'EGP']
  discount_amount Decimal [not null, default: 0]
  total_amount Decimal [not null]
  pricing_source PricingSource [not null, default: 'CUSTOM']
  created_at DateTime [default: `now()`, not null]
  updated_at DateTime [not null]
  invoice invoices [not null]
  service services
}

Table payments {
  id String [pk]
  invoice_id String [not null]
  amount Decimal [not null]
  currency String [not null, default: 'EGP']
  status PaymentStatus [not null, default: 'COMPLETED']
  payment_method PaymentMethod [not null]
  payment_date DateTime [not null]
  reference_number String
  notes String
  recorded_by_id String [not null]
  is_deleted Boolean [not null, default: false]
  deleted_at DateTime
  created_at DateTime [default: `now()`, not null]
  updated_at DateTime [not null]
  invoice invoices [not null]
  recorded_by profiles [not null]
  refunds refunds [not null]
}

Table refunds {
  id String [pk]
  payment_id String [not null]
  amount Decimal [not null]
  reason String [not null]
  status RefundStatus [not null, default: 'COMPLETED']
  refunded_by_id String [not null]
  refunded_at DateTime [default: `now()`, not null]
  is_deleted Boolean [not null, default: false]
  deleted_at DateTime
  created_at DateTime [default: `now()`, not null]
  updated_at DateTime [not null]
  payment payments [not null]
  refunded_by profiles [not null]
}

Table invoice_insurance_claims {
  id String [pk]
  invoice_id String [unique, not null]
  policy_number String [not null]
  covered_amount Decimal [not null]
  patient_copay Decimal [not null]
  status InsuranceClaimStatus [not null, default: 'PENDING']
  created_at DateTime [default: `now()`, not null]
  updated_at DateTime [not null]
  is_deleted Boolean [not null, default: false]
  deleted_at DateTime
  invoice invoices [not null]
}

