generator client {
  provider = "prisma-client-js"
}

generator dbml {
  provider = "prisma-dbml-generator"
}

datasource db {
  provider = "postgresql"
}

enum RegistrationStatus {
  PENDING
  ACTIVE
}

enum OrganizationStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum BranchStatus {
  ACTIVE
  INACTIVE
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  EXPIRED
  CANCELLED
}

enum BillingInterval {
  MONTHLY
  YEARLY
}

// Settlement provider for a subscription payment. Manual-proof providers
// (InstaPay, wallet) require an uploaded proof + offline verification today;
// automated gateways are added later behind the same PaymentProvider contract.
enum SubscriptionPaymentProvider {
  INSTAPAY
  WALLET
}

enum SubscriptionPaymentStatus {
  PENDING
  AWAITING_VERIFICATION
  VERIFIED
  REJECTED
  CANCELLED
}

// What a subscription payment buys: a base plan (activates/renews the
// subscription) or an add-on (grants extra branches/users on top of the plan).
enum SubscriptionPaymentPurpose {
  PLAN
  ADD_ON
  COMBINED
}

// A line on a COMBINED checkout: either the base PLAN or one ADD_ON purchase.
enum SubscriptionPaymentItemKind {
  PLAN
  ADD_ON
}

// An add-on stacks extra capacity on a base plan. BRANCH_BUNDLE adds a branch
// (with bundled users); EXTRA_USER adds a single user seat.
enum AddOnKind {
  BRANCH_BUNDLE
  EXTRA_USER
}

enum SubscriptionAddOnStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

