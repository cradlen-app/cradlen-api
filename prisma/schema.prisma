model Patient {
  id             String        @id @default(uuid()) @db.Uuid
  national_id    String        @unique
  full_name      String
  date_of_birth  DateTime      @db.Date
  phone_number   String
  address        String
  marital_status MaritalStatus @default(UNKNOWN)

  // Patient-uploaded profile image (R2 object key; served via short-lived
  // presigned GET). Null when no avatar has been set.
  profile_image_object_key String?

  // History snapshot fields and `husband_name` previously lived here and were
  // backfilled into PatientObgynHistory in the `patient_history_to_obgyn_history_only`
  // migration. PatientObgynHistory is now the only home — see @specialties/obgyn/patient-history.

  journeys        PatientJourney[]
  history_notes   PatientHistoryNote[]
  field_flags     PatientFieldFlag[]
  guardian_links  PatientGuardian[]
  guardian_record Guardian?              @relation("PatientGuardianRecord")
  account         PatientAccount?        @relation("PatientAccount")
  obgyn_history   PatientObgynHistory?
  calendar_events CalendarEvent[]
  enrollments     PatientOrgEnrollment[]
  invoices        Invoice[]              @relation("PatientInvoices")
  receipts        Receipt[]              @relation("PatientReceipts")
  charges         Charge[]               @relation("PatientCharges")
  notifications   PatientNotification[]

  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  is_deleted Boolean   @default(false)
  deleted_at DateTime?

  @@map("patients")
}

// In-app notifications addressed to a Patient (portal recipient) — distinct from
// the staff `Notification` (Profile-scoped). `organization_id` records the issuing
// org for context; `navigate_to` is a patient-portal-relative path (e.g. /tests).
model PatientNotification {
  id              String    @id @default(uuid()) @db.Uuid
  patient_id      String    @db.Uuid
  patient         Patient   @relation(fields: [patient_id], references: [id], onDelete: Cascade)
  organization_id String    @db.Uuid
  code            String
  category        String
  title           String
  description     String
  navigate_to     String?
  is_read         Boolean   @default(false)
  read_at         DateTime?
  metadata        Json?
  is_deleted      Boolean   @default(false)
  deleted_at      DateTime?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  @@index([patient_id, is_read, is_deleted])
  @@map("patient_notifications")
}

model PatientJourney {
  id                  String                  @id @default(uuid()) @db.Uuid
  patient_id          String                  @db.Uuid
  patient             Patient                 @relation(fields: [patient_id], references: [id], onDelete: Cascade)
  organization_id     String                  @db.Uuid
  organization        Organization            @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  journey_template_id String                  @db.Uuid
  journey_template    JourneyTemplate         @relation(fields: [journey_template_id], references: [id], onDelete: Cascade)
  care_path_id        String?                 @db.Uuid
  care_path           CarePath?               @relation(fields: [care_path_id], references: [id], onDelete: SetNull)
  created_by_id       String                  @db.Uuid
  created_by          Profile                 @relation(fields: [created_by_id], references: [id], onDelete: Cascade)
  status              JourneyStatus           @default(ACTIVE)
  started_at          DateTime                @default(now())
  ended_at            DateTime?
  episodes            PatientEpisode[]
  pregnancy_record    PregnancyJourneyRecord?
  surgical_record     SurgicalJourneyRecord?
  created_at          DateTime                @default(now())
  updated_at          DateTime                @updatedAt
  is_deleted          Boolean                 @default(false)
  deleted_at          DateTime?

  @@index([patient_id, organization_id, is_deleted])
  @@index([organization_id, status, is_deleted])
  @@index([care_path_id])
  // Partial unique index `patient_journeys_one_active_per_template` enforces at
  // most one ACTIVE, non-deleted journey per (patient_id, journey_template_id).
  // Added via raw SQL — partial indexes can't be expressed in the Prisma schema.
  @@map("patient_journeys")
}

model PatientEpisode {
  id                   String                  @id @default(uuid()) @db.Uuid
  journey_id           String                  @db.Uuid
  journey              PatientJourney          @relation(fields: [journey_id], references: [id], onDelete: Cascade)
  episode_template_id  String                  @db.Uuid
