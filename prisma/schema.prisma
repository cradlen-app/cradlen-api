model SubscriptionPlan {
  id                String                @id @default(uuid()) @db.Uuid
  plan              String                @unique
  max_organizations Int
  max_branches      Int
  max_staff         Int
  created_at        DateTime              @default(now())
  updated_at        DateTime              @updatedAt
  subscriptions     Subscription[]
  prices            PlanPrice[]
  payments          SubscriptionPayment[]
  payment_items     SubscriptionPaymentItem[]
  add_ons           AddOn[]

  @@map("subscription_plans")
}

// Per-interval price for a plan tier. Kept separate from SubscriptionPlan so a
// tier can carry multiple intervals/currencies (only YEARLY is seeded for now).
model PlanPrice {
  id                   String                @id @default(uuid()) @db.Uuid
  subscription_plan_id String                @db.Uuid
  billing_interval     BillingInterval
  price                Decimal               @db.Decimal(12, 2)
  currency             String                @default("EGP")
  is_active            Boolean               @default(true)
  is_deleted           Boolean               @default(false)
  deleted_at           DateTime?
  created_at           DateTime              @default(now())
  updated_at           DateTime              @updatedAt
  subscription_plan    SubscriptionPlan      @relation(fields: [subscription_plan_id], references: [id], onDelete: Cascade)
  payments             SubscriptionPayment[]
  payment_items        SubscriptionPaymentItem[]

  @@unique([subscription_plan_id, billing_interval, currency])
  @@map("plan_prices")
}

// An add-on tier: extra capacity that stacks on a specific base plan. Each row
// is scoped to one base plan (`subscription_plan_id`) because both the grant
// amount (bundled users) and the price differ per tier. Seed-managed, like
// SubscriptionPlan — no admin CRUD.
model AddOn {
  id                   String                @id @default(uuid()) @db.Uuid
  code                 String                @unique
  name                 String
  kind                 AddOnKind
  subscription_plan_id String                @db.Uuid
  delta_branches       Int                   @default(0)
  delta_users          Int                   @default(0)
  is_active            Boolean               @default(true)
  is_deleted           Boolean               @default(false)
  deleted_at           DateTime?
  created_at           DateTime              @default(now())
  updated_at           DateTime              @updatedAt
  subscription_plan    SubscriptionPlan      @relation(fields: [subscription_plan_id], references: [id], onDelete: Cascade)
  prices               AddOnPrice[]
  subscription_add_ons SubscriptionAddOn[]
  payments             SubscriptionPayment[]
  payment_items        SubscriptionPaymentItem[]

  @@index([subscription_plan_id, is_active])
  @@map("add_ons")
}

// Per-interval price for an add-on. Mirrors PlanPrice (only YEARLY seeded today).
model AddOnPrice {
  id               String          @id @default(uuid()) @db.Uuid
  add_on_id        String          @db.Uuid
  billing_interval BillingInterval
  price            Decimal         @db.Decimal(12, 2)
  currency         String          @default("EGP")
  is_active        Boolean         @default(true)
  is_deleted       Boolean         @default(false)
  deleted_at       DateTime?
  created_at       DateTime        @default(now())
  updated_at       DateTime        @updatedAt
  add_on           AddOn           @relation(fields: [add_on_id], references: [id], onDelete: Cascade)

  @@unique([add_on_id, billing_interval, currency])
  @@map("add_on_prices")
}

// An add-on an org owns against its current subscription. Effective limits =
// base plan + Σ(quantity × delta) over ACTIVE, unexpired rows. `ends_at` tracks
// the subscription's `ends_at` (co-terminus); add-ons renew with the base plan.
model SubscriptionAddOn {
  id              String                  @id @default(uuid()) @db.Uuid
  subscription_id String                  @db.Uuid
  add_on_id       String                  @db.Uuid
  quantity        Int                     @default(1)
  status          SubscriptionAddOnStatus @default(ACTIVE)
  starts_at       DateTime                @default(now())
  ends_at         DateTime?
  is_deleted      Boolean                 @default(false)
  deleted_at      DateTime?
  created_at      DateTime                @default(now())
  updated_at      DateTime                @updatedAt
  subscription    Subscription            @relation(fields: [subscription_id], references: [id], onDelete: Cascade)
  add_on          AddOn                   @relation(fields: [add_on_id], references: [id])

  @@unique([subscription_id, add_on_id])
  @@index([subscription_id, status])
  @@map("subscription_add_ons")
}

// A payment toward an org subscription. For manual-proof providers the owner
// pays out-of-band, uploads proof, and the payment is verified offline, which
// activates the org subscription. `amount`/`currency` are snapshotted from the
// resolved PlanPrice at creation so later price changes never alter this record.
// `submitted_by_id` (the OWNER profile) and `verified_by_id` (future platform
// admin) are plain columns with no FK — same convention as DiagnosisCode.
model SubscriptionPayment {
  id                   String                      @id @default(uuid()) @db.Uuid
  organization_id      String                      @db.Uuid
  subscription_id      String?                     @db.Uuid
  subscription_plan_id String                      @db.Uuid
  plan_price_id        String?                     @db.Uuid
  purpose              SubscriptionPaymentPurpose  @default(PLAN)
  add_on_id            String?                     @db.Uuid
  quantity             Int                         @default(1)
  provider             SubscriptionPaymentProvider
  provider_ref         String?
  billing_interval     BillingInterval
  amount               Decimal                     @db.Decimal(12, 2)
  currency             String                      @default("EGP")
  status               SubscriptionPaymentStatus   @default(PENDING)
  submitted_by_id      String?                     @db.Uuid
  verified_by_id       String?                     @db.Uuid
  verified_at          DateTime?
  rejection_reason     String?
  is_deleted           Boolean                     @default(false)
  deleted_at           DateTime?
  created_at           DateTime                    @default(now())
  updated_at           DateTime                    @updatedAt
  organization         Organization                @relation("OrgSubscriptionPayments", fields: [organization_id], references: [id], onDelete: Cascade)
  subscription         Subscription?               @relation(fields: [subscription_id], references: [id], onDelete: SetNull)
  subscription_plan    SubscriptionPlan            @relation(fields: [subscription_plan_id], references: [id])
  plan_price           PlanPrice?                  @relation(fields: [plan_price_id], references: [id], onDelete: SetNull)
  add_on               AddOn?                      @relation(fields: [add_on_id], references: [id], onDelete: SetNull)
  proofs               SubscriptionPaymentProof[]
  items                SubscriptionPaymentItem[]

  @@index([organization_id, status])
  @@map("subscription_payments")
}

// A line on a COMBINED checkout (one payment buys a plan AND add-ons in a single
// amount/proof). Canonical only for COMBINED payments; PLAN-only / ADD_ON-only
// payments keep their header-column shape. unit_amount/amount are snapshots so a
// later price change never alters a captured line.
model SubscriptionPaymentItem {
  id                      String                      @id @default(uuid()) @db.Uuid
  subscription_payment_id String                      @db.Uuid
  kind                    SubscriptionPaymentItemKind
  subscription_plan_id    String?                     @db.Uuid
  plan_price_id           String?                     @db.Uuid
  add_on_id               String?                     @db.Uuid
  quantity                Int                         @default(1)
  unit_amount             Decimal                     @db.Decimal(12, 2)
  amount                  Decimal                     @db.Decimal(12, 2)
  is_deleted              Boolean                     @default(false)
  deleted_at              DateTime?
  created_at              DateTime                    @default(now())
  updated_at              DateTime                    @updatedAt
  payment                 SubscriptionPayment         @relation(fields: [subscription_payment_id], references: [id], onDelete: Cascade)
  subscription_plan       SubscriptionPlan?           @relation(fields: [subscription_plan_id], references: [id])
  plan_price              PlanPrice?                  @relation(fields: [plan_price_id], references: [id], onDelete: SetNull)
  add_on                  AddOn?                      @relation(fields: [add_on_id], references: [id], onDelete: SetNull)

  @@index([subscription_payment_id])
  @@map("subscription_payment_items")
}

// Uploaded proof-of-payment file(s) for a manual-settlement payment. Stored in
// R2 (private); the row holds the object_key, served via short-lived presigned
// GET. Mirrors VisitInvestigationAttachment.
model SubscriptionPaymentProof {
  id                      String              @id @default(uuid()) @db.Uuid
  subscription_payment_id String              @db.Uuid
  object_key              String
  content_type            String?
  size_bytes              Int?
  is_deleted              Boolean             @default(false)
  deleted_at              DateTime?
  created_at              DateTime            @default(now())
  updated_at              DateTime            @updatedAt
  payment                 SubscriptionPayment @relation(fields: [subscription_payment_id], references: [id], onDelete: Cascade)

  @@index([subscription_payment_id, is_deleted])
  @@map("subscription_payment_proofs")
}

model Organization {
  id                      String                  @id @default(uuid()) @db.Uuid
  name                    String
  status                  OrganizationStatus      @default(ACTIVE)
  // Org logo (R2 object key; served via short-lived presigned GET). Null when
  // no logo has been set. Mirrors Profile.profile_image_object_key.
  logo_object_key         String?
  is_deleted              Boolean                 @default(false)
  deleted_at              DateTime?
  created_at              DateTime                @default(now())
  updated_at              DateTime                @updatedAt
  branches                Branch[]
  profiles                Profile[]
  invitations             Invitation[]
  subscriptions           Subscription[]
  patient_journeys        PatientJourney[]
  specialty_links         OrganizationSpecialty[]
  medications             Medication[]
  lab_tests               LabTest[]
  patient_history_notes   PatientHistoryNote[]
  field_flags             PatientFieldFlag[]
  care_paths              CarePath[]
  care_path_episodes      CarePathEpisode[]
  medical_reps            MedicalRep[]
  medical_rep_visits      MedicalRepVisit[]
  calendar_events         CalendarEvent[]
  patient_org_enrollments PatientOrgEnrollment[]
  services                Service[]               @relation("OrgServices")
  service_categories      ServiceCategory[]       @relation("OrgServiceCategories")
  price_lists             PriceList[]             @relation("OrgPriceLists")
  provider_services       ProviderService[]       @relation("OrgProviderServices")
  provider_overrides      ProviderPriceOverride[] @relation("OrgPriceOverrides")
  invoice_sequences       InvoiceSequence[]       @relation("OrgInvoiceSequences")
  invoices                Invoice[]               @relation("OrgInvoices")
  receipts                Receipt[]               @relation("OrgReceipts")
  receipt_sequences       ReceiptSequence[]       @relation("OrgReceiptSequences")
  charges                 Charge[]                @relation("OrgCharges")
  cash_sessions           CashSession[]           @relation("OrgCashSessions")
  subscription_payments   SubscriptionPayment[]   @relation("OrgSubscriptionPayments")

  @@index([status, is_deleted])
  @@map("organizations")
}

model Branch {
  id                 String                  @id @default(uuid()) @db.Uuid
  name               String
  address            String
  city               String
  governorate        String
  country            String?
  is_main            Boolean                 @default(false)
  status             BranchStatus            @default(ACTIVE)
  is_deleted         Boolean                 @default(false)
  deleted_at         DateTime?
  created_at         DateTime                @default(now())
  updated_at         DateTime                @updatedAt
  organization_id    String                  @db.Uuid
  organization       Organization            @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  profileBranches    ProfileBranch[]
  invitationBranches InvitationBranch[]
  workingSchedules   WorkingSchedule[]
  visits             Visit[]
  medical_rep_visits MedicalRepVisit[]
  calendar_events    CalendarEvent[]
  price_lists        PriceList[]             @relation("BranchPriceLists")
  provider_services  ProviderService[]       @relation("BranchProviderServices")
  provider_overrides ProviderPriceOverride[] @relation("BranchPriceOverrides")
  invoices           Invoice[]               @relation("BranchInvoices")
  receipts           Receipt[]               @relation("BranchReceipts")
  charges            Charge[]                @relation("BranchCharges")
  cash_sessions      CashSession[]           @relation("BranchCashSessions")

  @@unique([id, organization_id])
  @@index([organization_id, is_deleted])
  @@map("branches")
}

model User {
  id                   String               @id @default(uuid()) @db.Uuid
  first_name           String
  last_name            String
  email                String?              @unique
  phone_number         String?
  date_of_birth        DateTime?            @db.Date
  password_hashed      String?
  // Set whenever the password changes (reset flows). The staff JWT strategy
  // rejects access tokens issued before this instant, so a credential change
  // invalidates outstanding access tokens immediately — not just refresh tokens.
  password_changed_at  DateTime?
  is_active            Boolean              @default(true)
  is_deleted           Boolean              @default(false)
  deleted_at           DateTime?
  verified_at          DateTime?
  registration_status  RegistrationStatus   @default(PENDING)
  onboarding_completed Boolean              @default(false)
  created_at           DateTime             @default(now())
  updated_at           DateTime             @updatedAt
  // `users` is staff-only. Patient/guardian portal logins live in the dedicated
  // `patient_accounts` table (PatientAccount) — see core/patient-portal/auth.
  profiles             Profile[]
  refreshTokens        RefreshToken[]
  verificationCodes    VerificationCode[]
  passwordResetTokens  PasswordResetToken[]
  authAuditLogs        AuthAuditLog[]
  sentInvitations      Invitation[]         @relation("InvitedBy")

  @@index([registration_status, onboarding_completed])
  @@map("users")
}

// Portal login for a self-registered patient/guardian. Deliberately separate
// from `users` (staff identities): patients have no email, no Profile, no
// org/roles, log in by national_id, and authenticate via the `patient-jwt`
// strategy. Exactly one of patient_id / guardian_id is set (@unique enforces one
// account per subject and closes the double-signup race -> P2002). Credentials +
// knowledge-based recovery (security question/answer) live here; nothing else.
model PatientAccount {
  id                     String         @id @default(uuid()) @db.Uuid
  password_hashed        String?
  // Knowledge-based recovery (patients have no email). Set at self-signup or via
  // the profile "set security question" endpoint; verified by forgot-password.
  security_question      String?
  security_answer_hashed String?
  is_active              Boolean        @default(true)
  is_deleted             Boolean        @default(false)
  deleted_at             DateTime?
  patient_id             String?        @unique @db.Uuid
  guardian_id            String?        @unique @db.Uuid
  patient                Patient?       @relation("PatientAccount", fields: [patient_id], references: [id], onDelete: SetNull)
  guardian               Guardian?      @relation("GuardianAccount", fields: [guardian_id], references: [id], onDelete: SetNull)
  refreshTokens          RefreshToken[]
  created_at             DateTime       @default(now())
  updated_at             DateTime       @updatedAt

  @@map("patient_accounts")
}

// Platform operator (Cradlen staff) — a third auth audience alongside User
// (staff) and PatientAccount (portal). Has NO organization; authenticated via
// the `admin-jwt` strategy, never the org-scoped JwtAuthGuard. Flat tier: every
// admin can do everything. First row is seeded from env (no self-signup).
model PlatformAdmin {
  id                String             @id @default(uuid()) @db.Uuid
  email             String             @unique
  password_hashed   String?
  full_name         String
  role              PlatformAdminRole  @default(SUPER_ADMIN)
  is_active         Boolean            @default(true)
  is_deleted        Boolean            @default(false)
  deleted_at        DateTime?
  created_at        DateTime           @default(now())
  updated_at        DateTime           @updatedAt
  refreshTokens     RefreshToken[]
  auditLogs         AdminAuditLog[]
  verificationCodes VerificationCode[]

  @@map("platform_admins")
}

// Coarse role label for the admin team list. Authorization is still flat (any
// active admin is fully authorized); this only drives the Settings UI badge.
enum PlatformAdminRole {
  SUPER_ADMIN
  BILLING
}

// Singleton platform configuration surfaced on the admin Settings page: the
// manual-payment accounts shown to clinics plus a few global defaults. Exactly
// one row exists; services read/write it via an upsert on a fixed sentinel id.
model PlatformSetting {
  id                           String   @id @default(uuid()) @db.Uuid
  instapay_handle              String?
  wallet_number                String?
  free_trial_days              Int      @default(14)
  auto_verify_gateway_payments Boolean  @default(true)
  default_currency             String   @default("EGP")
  created_at                   DateTime @default(now())
  updated_at                   DateTime @updatedAt

  @@map("platform_settings")
}

// What kind of platform event a notification records.
enum AdminNotificationType {
  ORGANIZATION_CREATED
  SUBSCRIPTION_STARTED
  PLAN_CHANGED
  PAYMENT_SUBMITTED
}

// Platform-wide admin notification feed (shared across the small admin team, so
// read-state is a single flag rather than per-admin). Materialized by the
// AdminNotificationsListener from domain events.
model AdminNotification {
  id              String                @id @default(uuid()) @db.Uuid
  type            AdminNotificationType
  title           String
  body            String
  organization_id String?               @db.Uuid
  related_id      String?               @db.Uuid
  is_read         Boolean               @default(false)
  created_at      DateTime              @default(now())

  @@index([is_read, created_at])
  @@map("admin_notifications")
}

// Append-only audit trail for every platform-admin WRITE action. Written inside
// the same transaction as the mutation it records, so the action and its log are
// atomic. before/after hold the relevant snapshot of the mutated entity.
model AdminAuditLog {
  id          String        @id @default(uuid()) @db.Uuid
  admin_id    String        @db.Uuid
  action      String
  target_type String
  target_id   String?
  before      Json?
  after       Json?
  created_at  DateTime      @default(now())
  admin       PlatformAdmin @relation(fields: [admin_id], references: [id], onDelete: Cascade)

  @@index([admin_id, created_at])
  @@index([target_type, target_id])
  @@map("admin_audit_log")
}

model Role {
  id          String       @id @default(uuid()) @db.Uuid
  code        String       @unique
  name        String       @unique
  created_at  DateTime     @default(now())
  updated_at  DateTime     @updatedAt
  profiles    Profile[]
  invitations Invitation[]

  @@map("roles")
}

model JobFunction {
  id          String       @id @default(uuid()) @db.Uuid
  name        String       @unique
  code        String       @unique
  is_clinical Boolean      @default(false)
  created_at  DateTime     @default(now())
  updated_at  DateTime     @updatedAt
  profiles    Profile[]
  invitations Invitation[]

  @@map("job_functions")
}

model Profile {
  id                               String                           @id @default(uuid()) @db.Uuid
  user_id                          String                           @db.Uuid
  organization_id                  String                           @db.Uuid
  role_id                          String                           @db.Uuid
  job_function_id                  String?                          @db.Uuid
  specialty_id                     String?                          @db.Uuid
  executive_title                  ExecutiveTitle?
  professional_title               String?
  engagement_type                  EngagementType                   @default(FULL_TIME)
  profile_image_object_key         String?
  is_active                        Boolean                          @default(true)
  is_deleted                       Boolean                          @default(false)
  deleted_at                       DateTime?
  created_at                       DateTime                         @default(now())
  updated_at                       DateTime                         @updatedAt
  user                             User                             @relation(fields: [user_id], references: [id], onDelete: Cascade)
  organization                     Organization                     @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  role                             Role                             @relation(fields: [role_id], references: [id])
  job_function                     JobFunction?                     @relation(fields: [job_function_id], references: [id])
  specialty                        Specialty?                       @relation(fields: [specialty_id], references: [id])
  branches                         ProfileBranch[]
  workingSchedules                 WorkingSchedule[]
  subspecialty_links               ProfileSubspecialty[]
  created_journeys                 PatientJourney[]
  doctor_visits                    Visit[]                          @relation("DoctorVisits")
  created_visits                   Visit[]                          @relation("CreatedVisits")
  medications_added                Medication[]                     @relation("MedicationAddedBy")
  lab_tests_added                  LabTest[]                        @relation("LabTestAddedBy")
  vitals_recorded                  VisitVitals[]                    @relation("VitalsRecordedBy")
  investigations_ordered           VisitInvestigation[]             @relation("InvestigationOrderedBy")
  investigations_resulted          VisitInvestigation[]             @relation("InvestigationResultedBy")
  investigations_reviewed          VisitInvestigation[]             @relation("InvestigationReviewedBy")
  prescriptions_authored           Prescription[]                   @relation("PrescriptionPrescribedBy")
  history_notes_authored           PatientHistoryNote[]             @relation("HistoryNoteAuthor")
  authored_field_flags             PatientFieldFlag[]               @relation("FieldFlagAuthor")
  // Updated-by back-relations for clinical mutable rows that have a revision
  // shadow table (PR4). History sub-tables that are list-style records are
  // not versioned individually — their audit lives on the PatientObgynHistory
  // snapshot row.
  patient_obgyn_history_updates    PatientObgynHistory[]            @relation("PatientObgynHistoryUpdatedBy")
  visit_obgyn_encounter_updates    VisitObgynEncounter[]            @relation("VisitObgynEncounterUpdatedBy")
  pregnancy_journey_updates        PregnancyJourneyRecord[]         @relation("PregnancyJourneyRecordUpdatedBy")
  pregnancy_episode_updates        PregnancyEpisodeRecord[]         @relation("PregnancyEpisodeRecordUpdatedBy")
  visit_pregnancy_updates          VisitPregnancyRecord[]           @relation("VisitPregnancyRecordUpdatedBy")
  visit_fetal_updates              VisitFetalRecord[]               @relation("VisitFetalRecordUpdatedBy")
  surgical_journey_updates         SurgicalJourneyRecord[]          @relation("SurgicalJourneyRecordUpdatedBy")
  surgical_episode_updates         SurgicalEpisodeRecord[]          @relation("SurgicalEpisodeRecordUpdatedBy")
  visit_surgical_updates           VisitSurgicalRecord[]            @relation("VisitSurgicalRecordUpdatedBy")
  visit_encounter_updates          VisitEncounter[]                 @relation("VisitEncounterUpdatedBy")
  prescription_updates             Prescription[]                   @relation("PrescriptionUpdatedBy")
  prescription_item_updates        PrescriptionItem[]               @relation("PrescriptionItemUpdatedBy")
  investigation_updates            VisitInvestigation[]             @relation("VisitInvestigationUpdatedBy")
  // PR4: revision shadow tables — author back-relations
  patient_obgyn_history_revisions  PatientObgynHistoryRevision[]    @relation("PatientObgynHistoryRevisedBy")
  visit_encounter_revisions        VisitEncounterRevision[]         @relation("VisitEncounterRevisedBy")
  visit_obgyn_encounter_revisions  VisitObgynEncounterRevision[]    @relation("VisitObgynEncounterRevisedBy")
  prescription_revisions           PrescriptionRevision[]           @relation("PrescriptionRevisedBy")
  prescription_item_revisions      PrescriptionItemRevision[]       @relation("PrescriptionItemRevisedBy")
  pregnancy_journey_revisions      PregnancyJourneyRecordRevision[] @relation("PregnancyJourneyRecordRevisedBy")
  pregnancy_episode_revisions      PregnancyEpisodeRecordRevision[] @relation("PregnancyEpisodeRecordRevisedBy")
  visit_pregnancy_revisions        VisitPregnancyRecordRevision[]   @relation("VisitPregnancyRecordRevisedBy")
  visit_fetal_revisions            VisitFetalRecordRevision[]       @relation("VisitFetalRecordRevisedBy")
  surgical_journey_revisions       SurgicalJourneyRecordRevision[]  @relation("SurgicalJourneyRecordRevisedBy")
  surgical_episode_revisions       SurgicalEpisodeRecordRevision[]  @relation("SurgicalEpisodeRecordRevisedBy")
  visit_surgical_revisions         VisitSurgicalRecordRevision[]    @relation("VisitSurgicalRecordRevisedBy")
  // Builder / medical-rep back-relations
  form_templates_created           FormTemplate[]                   @relation("FormTemplateCreatedBy")
  form_templates_updated           FormTemplate[]                   @relation("FormTemplateUpdatedBy")
  medical_rep_visits_doctor        MedicalRepVisit[]                @relation("MedRepVisitDoctor")
  medical_rep_visits_created       MedicalRepVisit[]                @relation("MedRepVisitCreatedBy")
  calendar_events                  CalendarEvent[]                  @relation("CalendarEventProfile")
  calendar_event_assists           CalendarEventAssistant[]         @relation("CalendarEventAssistantProfile")
  notifications                    Notification[]
  // Financial back-relations
  services_created                 Service[]                        @relation("ServiceCreatedBy")
  service_categories_created       ServiceCategory[]                @relation("ServiceCategoryCreatedBy")
  price_lists_created              PriceList[]                      @relation("PriceListCreatedBy")
  price_list_items_created         PriceListItem[]                  @relation("PriceListItemCreatedBy")
  provider_services                ProviderService[]                @relation("ProfileProviderServices")
  provider_services_created        ProviderService[]                @relation("ProviderServiceCreatedBy")
  provider_price_overrides         ProviderPriceOverride[]          @relation("ProfilePriceOverrides")
  provider_price_overrides_created ProviderPriceOverride[]          @relation("ProviderPriceOverrideCreatedBy")
  invoices_created                 Invoice[]                        @relation("InvoiceCreatedBy")
  invoices_as_doctor               Invoice[]                        @relation("InvoiceDoctor")
  charges_as_provider              Charge[]                         @relation("ChargeProvider")
  charges_captured                 Charge[]                         @relation("ChargeCapturedBy")
  payments_recorded                Payment[]                        @relation("PaymentRecordedBy")
  refunds_issued                   Refund[]                         @relation("RefundedBy")
  receipts_issued                  Receipt[]                        @relation("ReceiptIssuedBy")
  cash_sessions_as_cashier         CashSession[]                    @relation("CashSessionCashier")
  cash_sessions_opened             CashSession[]                    @relation("CashSessionOpenedBy")
  cash_sessions_closed             CashSession[]                    @relation("CashSessionClosedBy")

  @@unique([user_id, organization_id])
  @@index([organization_id, is_deleted])
  @@index([user_id, is_deleted])
  @@index([role_id])
  @@index([job_function_id])
  @@index([specialty_id])
  @@map("profiles")
}

model ProfileBranch {
  id              String   @id @default(uuid()) @db.Uuid
  profile_id      String   @db.Uuid
  branch_id       String   @db.Uuid
  organization_id String   @db.Uuid
  created_at      DateTime @default(now())
  profile         Profile  @relation(fields: [profile_id], references: [id], onDelete: Cascade)
  branch          Branch   @relation(fields: [branch_id, organization_id], references: [id, organization_id], onDelete: Cascade)

  @@unique([profile_id, branch_id])
  @@index([organization_id, branch_id])
  @@map("profile_branches")
}

model Subscription {
  id                   String                @id @default(uuid()) @db.Uuid
  organization_id      String                @db.Uuid
  subscription_plan_id String                @db.Uuid
  status               SubscriptionStatus    @default(TRIAL)
  starts_at            DateTime              @default(now())
  ends_at              DateTime?
  trial_ends_at        DateTime?
  created_at           DateTime              @default(now())
  updated_at           DateTime              @updatedAt
  is_deleted           Boolean               @default(false)
  deleted_at           DateTime?
  organization         Organization          @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  subscription_plan    SubscriptionPlan      @relation(fields: [subscription_plan_id], references: [id])
  payments             SubscriptionPayment[]
  add_ons              SubscriptionAddOn[]

  @@index([organization_id, is_deleted])
  @@map("subscriptions")
