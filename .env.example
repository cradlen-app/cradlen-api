# =============================================================================
# Application
# =============================================================================
APP_NAME=cradlen-api
NODE_ENV=development
PORT=3000

# =============================================================================
# API
# =============================================================================
API_DEFAULT_VERSION=1

# =============================================================================
# Database (Neon PostgreSQL)
# Get these from your Neon dashboard -> Connection Details
# =============================================================================
DATABASE_URL=postgresql://<user>:<password>@<pooler-host>/<db>?sslmode=require&channel_binding=require
DIRECT_URL=postgresql://<user>:<password>@<direct-host>/<db>?sslmode=require&channel_binding=require

# =============================================================================
# Logging
# Values: trace | debug | info | warn | error | fatal
# =============================================================================
LOG_LEVEL=info

# =============================================================================
# CORS
# Comma-separated list of allowed origins. Leave empty to deny all.
# =============================================================================
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# =============================================================================
# Rate Limiting
# TTL in milliseconds, LIMIT = max requests per TTL window per IP
# =============================================================================
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# =============================================================================
# Localisation
# =============================================================================
DEFAULT_LOCALE=en
SUPPORTED_LOCALES=en,ar
FALLBACK_LOCALE=en

# =============================================================================
# Auth (JWT)
# =============================================================================
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
JWT_REGISTRATION_EXPIRATION=30m

# =============================================================================
# Email (Resend)
# Get API key from https://resend.com/api-keys
# =============================================================================
RESEND_API_KEY=re_xxxxxxxxxxxx
# Use your verified domain address in production.
# While Cloudflare DNS is unresolved, use onboarding@resend.dev (Resend sandbox sender — no domain verification needed).
RESEND_FROM_EMAIL=noreply@yourdomain.com

# =============================================================================
# Subscription
# =============================================================================
FREE_TRIAL_DAYS=14
