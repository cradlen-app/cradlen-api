// Result files/images attached to an investigation. Multiple per investigation
// (patient-uploaded scans, lab PDFs, …). `source` distinguishes who uploaded it;
// patient uploads have no Profile so there is no uploader FK. The object lives in
// R2 (private) — `object_key` is the bucket key, read via a presigned GET URL.
model VisitInvestigationAttachment {
  id               String                    @id @default(uuid()) @db.Uuid
  investigation_id String                    @db.Uuid
  investigation    VisitInvestigation        @relation(fields: [investigation_id], references: [id], onDelete: Cascade)
  object_key       String
  content_type     String?
  size_bytes       Int?
  source           InvestigationResultSource @default(PATIENT)
  is_deleted       Boolean                   @default(false)
  deleted_at       DateTime?
  created_at       DateTime                  @default(now())
  updated_at       DateTime                  @updatedAt

  @@index([investigation_id, is_deleted])
  @@map("visit_investigation_attachments")
}

// Structured, ICD-10-coded diagnoses for a visit (repeatable). One primary +
// any number of secondary diagnoses. Mirrors VisitInvestigation's per-visit
// id-keyed diff write path. The encounter's `provisional_diagnosis` text is a
// server-derived mirror of the primary row.
model VisitDiagnosis {
  id            String    @id @default(uuid()) @db.Uuid
  visit_id      String    @db.Uuid
  visit         Visit     @relation(fields: [visit_id], references: [id], onDelete: Cascade)
  code          String // ICD-10 code, e.g. "N80.0"
  description   String
  is_primary    Boolean   @default(false)
  certainty     String? // SUSPECTED | PROBABLE | CONFIRMED
  order         Int       @default(0)
  created_by_id String?   @db.Uuid
  is_deleted    Boolean   @default(false)
  deleted_at    DateTime?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  @@index([visit_id, is_deleted])
  @@map("visit_diagnoses")
}

enum DiagnosisCodeSource {
  SYSTEM
  USER
}

// System-wide ICD-10 diagnosis catalog (seed-managed, like specialties /
// care paths). Search-only over HTTP; backs the diagnosis type-ahead picker.
// `code` is the stored value on VisitDiagnosis (no FK — free entry stays valid).
// Rows are either SYSTEM (seeded) or USER (added at examination time when a
// doctor enters a code not yet in the catalog); `created_by_id` records the
// authoring profile for USER rows (plain column, no FK — same convention).
model DiagnosisCode {
  id             String              @id @default(uuid()) @db.Uuid
  code           String // ICD-10-CM code
  description    String
  chapter        String? // clinical-concept group (e.g. "Pregnancy", "Gynecology")
  specialty_code String? // e.g. "OBGYN"
  billable       Boolean             @default(true)
  keywords       String? // extra search terms / synonyms
  source         DiagnosisCodeSource @default(SYSTEM)
  created_by_id  String?             @db.Uuid // authoring profile for USER rows
  is_deleted     Boolean             @default(false)
  deleted_at     DateTime?
  created_at     DateTime            @default(now())
  updated_at     DateTime            @updatedAt

  @@unique([code])
  @@index([specialty_code])
  @@map("diagnosis_codes")
}

model Prescription {
