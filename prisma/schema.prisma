model Specialty {
  id                  String                  @id @default(uuid()) @db.Uuid
  name                String                  @unique
  code                String                  @unique
  description         String?
  templates           JourneyTemplate[]
  care_paths          CarePath[]
  procedures          Procedure[]
  subspecialties      Subspecialty[]
  profiles            Profile[]
  invitations         Invitation[]
  org_links           OrganizationSpecialty[]
  lab_tests           LabTest[]
  form_templates      FormTemplate[]
  service_specialties ServiceSpecialty[]      @relation("SpecialtyServices")
  created_at          DateTime                @default(now())
  updated_at          DateTime                @updatedAt
  is_deleted          Boolean                 @default(false)
  deleted_at          DateTime?

  @@map("specialties")
}

model Procedure {
  id           String    @id @default(uuid()) @db.Uuid
  specialty_id String    @db.Uuid
  name         String
  code         String    @unique
