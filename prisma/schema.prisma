model RefreshToken {
  id                 String          @id @default(uuid()) @db.Uuid
  jti                String          @unique @db.Uuid
  token_hash         String
  // Exactly one owner is set: `user_id` for a staff session, `patient_account_id`
  // for a patient/guardian portal session, `platform_admin_id` for a platform-admin
  // session. Enforced by a CHECK constraint (`refresh_tokens_exactly_one_owner`)
  // added in the migration raw SQL.
  user_id            String?         @db.Uuid
  patient_account_id String?         @db.Uuid
  platform_admin_id  String?         @db.Uuid
  profile_id         String?         @db.Uuid
  organization_id    String?         @db.Uuid
  active_branch_id   String?         @db.Uuid
  expires_at         DateTime
  is_revoked         Boolean         @default(false)
  revoked_at         DateTime?
  // jti of the token that replaced this one on rotation. Set only when a row
  // is revoked *by rotation* (never by logout), so the refresh endpoint can
  // tell a rotation-race retry apart from a genuine replay / logout.
  replaced_by_jti    String?         @db.Uuid
  created_at         DateTime        @default(now())
  user               User?           @relation(fields: [user_id], references: [id], onDelete: Cascade)
  patientAccount     PatientAccount? @relation(fields: [patient_account_id], references: [id], onDelete: Cascade)
  platformAdmin      PlatformAdmin?  @relation(fields: [platform_admin_id], references: [id], onDelete: Cascade)

  @@index([user_id, is_revoked])
  @@index([patient_account_id, is_revoked])
  @@index([platform_admin_id, is_revoked])
  @@map("refresh_tokens")
}

// Audit trail for AUTH_EVENTS. Written by AuthAuditListener on every
// signup.completed / login.succeeded / login.failed /
// password_reset.completed / refresh.rotated event. Independent of
// rest of the request flow: a write failure must NOT bubble up and
// fail the user-facing action.
model AuthAuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  event_name String
  user_id    String?  @db.Uuid
  email      String?
  payload    Json
  at         DateTime
  created_at DateTime @default(now())
  user       User?    @relation(fields: [user_id], references: [id], onDelete: SetNull)

  @@index([user_id, created_at])
  @@index([event_name, created_at])
  @@map("auth_audit_log")
}

// Tracks reset tokens AFTER the verify step issues a verified token.
// PasswordResetService.verify writes one row; reset() looks the row up by
// jti and rejects re-use via consumed_at. Forgot-password.start does NOT
// write a row — synthesized tokens for unknown emails have no underlying
// user and the verify step short-circuits with INVALID_CODE before this
// table is touched, so symmetry with the real-but-wrong-code path holds.
model PasswordResetToken {
  id          String    @id @default(uuid()) @db.Uuid
  jti         String    @unique @db.Uuid
  user_id     String    @db.Uuid
  target      String
  expires_at  DateTime
  consumed_at DateTime?
  created_at  DateTime  @default(now())
  user        User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("password_reset_tokens")
}

model VerificationCode {
  id           String              @id @default(uuid()) @db.Uuid
  // user_id for staff/patient flows; admin_id for the ADMIN_LOGIN flow. Platform
  // admins are not Users, so their OTP rows key on admin_id (target/purpose still
  // index the lookup).
  user_id      String?             @db.Uuid
  admin_id     String?             @db.Uuid
  channel      VerificationChannel
  purpose      VerificationPurpose
  target       String
  code_hash    String
  attempts     Int                 @default(0)
  max_attempts Int                 @default(5)
  is_resend    Boolean             @default(false)
  expires_at   DateTime
  consumed_at  DateTime?
  created_at   DateTime            @default(now())
  user         User?               @relation(fields: [user_id], references: [id], onDelete: Cascade)
  admin        PlatformAdmin?      @relation(fields: [admin_id], references: [id], onDelete: Cascade)

  @@index([target, purpose, consumed_at])
  @@index([user_id, purpose])
  @@index([admin_id, purpose])
  @@map("verification_codes")
}

model Invitation {
  id                 String                   @id @default(uuid()) @db.Uuid
  organization_id    String                   @db.Uuid
  invited_by_id      String                   @db.Uuid
  role_id            String                   @db.Uuid
  job_function_id    String?                  @db.Uuid
  specialty_id       String?                  @db.Uuid
  email              String
  first_name         String
  last_name          String
  phone_number       String?
  executive_title    ExecutiveTitle?
  professional_title String?
  engagement_type    EngagementType           @default(FULL_TIME)
  token_hash         String                   @unique
  status             InvitationStatus         @default(PENDING)
  expires_at         DateTime
  accepted_at        DateTime?
  is_deleted         Boolean                  @default(false)
  deleted_at         DateTime?
  created_at         DateTime                 @default(now())
  updated_at         DateTime                 @updatedAt
  organization       Organization             @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  invited_by         User                     @relation("InvitedBy", fields: [invited_by_id], references: [id])
  role               Role                     @relation(fields: [role_id], references: [id])
  job_function       JobFunction?             @relation(fields: [job_function_id], references: [id])
  specialty          Specialty?               @relation(fields: [specialty_id], references: [id])
  branches           InvitationBranch[]
  subspecialty_links InvitationSubspecialty[]

  @@index([organization_id, status])
  @@index([email])
  @@index([expires_at])
  @@index([status, expires_at])
  @@index([specialty_id])
  // Partial unique index `invitations_org_email_pending_unique` added via raw
  // SQL in the `invitations_hardening` migration (Prisma cannot express
  // partial unique indexes natively).
  @@map("invitations")
}

model InvitationBranch {
  id              String     @id @default(uuid()) @db.Uuid
  invitation_id   String     @db.Uuid
  branch_id       String     @db.Uuid
  organization_id String     @db.Uuid
  created_at      DateTime   @default(now())
  invitation      Invitation @relation(fields: [invitation_id], references: [id], onDelete: Cascade)
  branch          Branch     @relation(fields: [branch_id, organization_id], references: [id, organization_id], onDelete: Cascade)

  @@unique([invitation_id, branch_id])
  @@index([organization_id, branch_id])
  @@map("invitation_branches")
}

model Notification {
  id          String    @id @default(uuid()) @db.Uuid
  // Notifications are scoped to a Profile (org membership), not a User. A person
  // with profiles in several orgs gets a distinct inbox per org — `navigate_to`
  // links resolve within that org's context.
  profile_id  String    @db.Uuid
  // Stable machine key drawn from the catalog at
  // @core/notifications/notification-codes.ts. `category` is the display label.
  code        String
  category    String
  title       String
  description String
  navigate_to String?
  is_read     Boolean   @default(false)
  read_at     DateTime?
  metadata    Json?
  is_deleted  Boolean   @default(false)
  deleted_at  DateTime?
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
  profile     Profile   @relation(fields: [profile_id], references: [id], onDelete: Cascade)

  @@index([profile_id, is_read, is_deleted])
  @@index([profile_id, category, is_deleted])
  @@index([profile_id, code, is_deleted])
  @@map("notifications")
}

model WorkingSchedule {
  id         String       @id @default(uuid()) @db.Uuid
  profile_id String       @db.Uuid
  branch_id  String       @db.Uuid
  created_at DateTime     @default(now())
  updated_at DateTime     @updatedAt
  profile    Profile      @relation(fields: [profile_id], references: [id], onDelete: Cascade)
  branch     Branch       @relation(fields: [branch_id], references: [id], onDelete: Cascade)
  days       WorkingDay[]

  @@unique([profile_id, branch_id])
  @@index([profile_id])
  @@map("working_schedules")
}

model WorkingDay {
  id          String          @id @default(uuid()) @db.Uuid
