generator client {
  provider = "prisma-client-js"
}

generator dbml {
  provider = "prisma-dbml-generator"
}

datasource db {
  provider = "postgresql"
}

enum RegistrationStatus {
  PENDING
  ACTIVE
}

enum OrganizationStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum BranchStatus {
  ACTIVE
  INACTIVE
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  EXPIRED
  CANCELLED
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  CANCELLED
}

enum DayOfWeek {
  MON
  TUE
  WED
  THU
  FRI
  SAT
  SUN
}

enum VerificationChannel {
  EMAIL
}

enum VerificationPurpose {
  SIGNUP
  LOGIN
  PASSWORD_RESET
}

enum JourneyTemplateType {
  PREGNANCY
  GENERAL_GYN
  SURGICAL
  CHRONIC_CONDITION
}

enum JourneyStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum PatientOrgEnrollmentStatus {
  PENDING
  ACTIVE
  DISCHARGED
}

enum EpisodeStatus {
  PENDING
  ACTIVE
  COMPLETED
}

enum AppointmentType {
  VISIT
  FOLLOW_UP
}

enum MaritalStatus {
  SINGLE
  MARRIED
  DIVORCED
  WIDOWED
  SEPARATED
  ENGAGED
  UNKNOWN
}

enum GuardianRelation {
  SPOUSE
  PARENT
  CHILD
  SIBLING
  GUARDIAN_LEGAL
  OTHER
}

enum FormScope {
  BOOK_VISIT
  ENCOUNTER
  PATIENT_HISTORY
}

enum FormTemplateStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum FormFieldType {
  TEXT
  TEXTAREA
  NUMBER
  DECIMAL
  DATE
  DATETIME
  BOOLEAN
  SELECT
  MULTISELECT
  ENTITY_SEARCH
  COMPUTED
}

enum BindingNamespace {
  PATIENT
  VISIT
  INTAKE
  GUARDIAN
  MEDICAL_REP
  LOOKUP
  SYSTEM
  COMPUTED
  PATIENT_OBGYN_HISTORY
  VISIT_ENCOUNTER
  VISIT_VITALS
  VISIT_OBGYN_ENCOUNTER
  VISIT_INVESTIGATION
  VISIT_DIAGNOSIS
  PRESCRIPTION_ITEM
  MEDICAL_REP_VISIT
}

enum MedicalRepVisitStatus {
  SCHEDULED
  CHECKED_IN
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum MedicalRepVisitPurpose {
  PRODUCT_DETAILING
  SAMPLE_DROP
  CONFERENCE_INVITE
  PRICE_UPDATE
  FOLLOW_UP
  COURTESY
  OTHER
}

enum MedicalRepVisitOutcome {
  NONE
  SCHEDULE_FOLLOWUP
  SHARE_MATERIALS
  NOT_INTERESTED
}

enum VisitPriority {
  NORMAL
  EMERGENCY
}

enum VisitStatus {
  SCHEDULED
  CHECKED_IN
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum ExecutiveTitle {
  CEO
  COO
  CFO
  CMO
}

enum EngagementType {
  FULL_TIME
  PART_TIME
  ON_DEMAND
  EXTERNAL_CONSULTANT
}

enum LabTestCategory {
  LAB
  IMAGING
  OTHER
}

enum InvestigationStatus {
  ORDERED
  RESULTED
  REVIEWED
  CANCELLED
}

enum InvestigationResultSource {
  CLINIC
  PATIENT
  EXTERNAL_LAB
}

enum NoteVisibility {
  PRIVATE_TO_ORG
  SHARED_GLOBAL
}

enum ServiceType {
  CONSULTATION
  PROCEDURE
  LAB_TEST
  IMAGING
  ADMINISTRATIVE
  OTHER
}

enum PricingSource {
  ORG_PRICE_LIST
  BRANCH_OVERRIDE
  PROVIDER_OVERRIDE
  CUSTOM
}

enum InvoiceType {
  STANDARD
  FOLLOWUP
  PROFORMA
  INSURANCE
  REFUND
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PARTIALLY_PAID
  PAID
  REFUNDED
  VOID
}

enum PaymentMethod {
  CASH
  CARD
  BANK_TRANSFER
  OTHER
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
  VOID
}

enum InsuranceClaimStatus {
  PENDING
  SUBMITTED
  APPROVED
  REJECTED
}

enum RefundStatus {
  PENDING
  COMPLETED
  FAILED
  VOID
}

model SubscriptionPlan {
  id                String         @id @default(uuid()) @db.Uuid
  plan              String         @unique
  max_organizations Int
  max_branches      Int
  max_staff         Int
  created_at        DateTime       @default(now())
  updated_at        DateTime       @updatedAt
  subscriptions     Subscription[]

  @@map("subscription_plans")
}

model Organization {
  id                      String                  @id @default(uuid()) @db.Uuid
  name                    String
  status                  OrganizationStatus      @default(ACTIVE)
  is_deleted              Boolean                 @default(false)
  deleted_at              DateTime?
  created_at              DateTime                @default(now())
  updated_at              DateTime                @updatedAt
  branches                Branch[]
  profiles                Profile[]
  invitations             Invitation[]
  subscriptions           Subscription[]
  patient_journeys        PatientJourney[]
  specialty_links         OrganizationSpecialty[]
  medications             Medication[]
  lab_tests               LabTest[]
  patient_history_notes   PatientHistoryNote[]
  field_flags             PatientFieldFlag[]
  care_paths              CarePath[]
  care_path_episodes      CarePathEpisode[]
  medical_reps            MedicalRep[]
  medical_rep_visits      MedicalRepVisit[]
  calendar_events         CalendarEvent[]
  patient_org_enrollments PatientOrgEnrollment[]
  services                Service[]               @relation("OrgServices")
  price_lists             PriceList[]             @relation("OrgPriceLists")
  provider_services       ProviderService[]       @relation("OrgProviderServices")
  provider_overrides      ProviderPriceOverride[] @relation("OrgPriceOverrides")
  invoice_sequences       InvoiceSequence[]       @relation("OrgInvoiceSequences")
  invoices                Invoice[]               @relation("OrgInvoices")

  @@index([status, is_deleted])
  @@map("organizations")
}

model Branch {
  id                 String                  @id @default(uuid()) @db.Uuid
  name               String
  address            String
  city               String
  governorate        String
  country            String?
  is_main            Boolean                 @default(false)
  status             BranchStatus            @default(ACTIVE)
  is_deleted         Boolean                 @default(false)
  deleted_at         DateTime?
  created_at         DateTime                @default(now())
  updated_at         DateTime                @updatedAt
  organization_id    String                  @db.Uuid
  organization       Organization            @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  profileBranches    ProfileBranch[]
  invitationBranches InvitationBranch[]
  workingSchedules   WorkingSchedule[]
  visits             Visit[]
  medical_rep_visits MedicalRepVisit[]
  calendar_events    CalendarEvent[]
  price_lists        PriceList[]             @relation("BranchPriceLists")
  provider_services  ProviderService[]       @relation("BranchProviderServices")
  provider_overrides ProviderPriceOverride[] @relation("BranchPriceOverrides")
  invoices           Invoice[]               @relation("BranchInvoices")

  @@unique([id, organization_id])
  @@index([organization_id, is_deleted])
  @@map("branches")
}

model User {
  id                   String               @id @default(uuid()) @db.Uuid
  first_name           String
  last_name            String
  email                String?              @unique
  phone_number         String?
  password_hashed      String?
  is_active            Boolean              @default(true)
  is_deleted           Boolean              @default(false)
  deleted_at           DateTime?
  verified_at          DateTime?
  registration_status  RegistrationStatus   @default(PENDING)
  onboarding_completed Boolean              @default(false)
  created_at           DateTime             @default(now())
  updated_at           DateTime             @updatedAt
  profiles             Profile[]
  refreshTokens        RefreshToken[]
  verificationCodes    VerificationCode[]
  passwordResetTokens  PasswordResetToken[]
  authAuditLogs        AuthAuditLog[]
  sentInvitations      Invitation[]         @relation("InvitedBy")

  @@index([registration_status, onboarding_completed])
  @@map("users")
}

model Role {
  id              String           @id @default(uuid()) @db.Uuid
  code            String           @unique
  name            String           @unique
  created_at      DateTime         @default(now())
  updated_at      DateTime         @updatedAt
  profileRoles    ProfileRole[]
  invitationRoles InvitationRole[]

  @@map("roles")
}

model JobFunction {
  id               String                  @id @default(uuid()) @db.Uuid
  name             String                  @unique
  code             String                  @unique
  is_clinical      Boolean                 @default(false)
  created_at       DateTime                @default(now())
  updated_at       DateTime                @updatedAt
  profile_links    ProfileJobFunction[]
  invitation_links InvitationJobFunction[]

  @@map("job_functions")
}

model ProfileJobFunction {
  id              String      @id @default(uuid()) @db.Uuid
  profile_id      String      @db.Uuid
  job_function_id String      @db.Uuid
  created_at      DateTime    @default(now())
  profile         Profile     @relation(fields: [profile_id], references: [id], onDelete: Cascade)
  job_function    JobFunction @relation(fields: [job_function_id], references: [id], onDelete: Cascade)

  @@unique([profile_id, job_function_id])
  @@index([job_function_id])
  @@map("profile_job_functions")
}

model Profile {
  id                               String                           @id @default(uuid()) @db.Uuid
  user_id                          String                           @db.Uuid
  organization_id                  String                           @db.Uuid
  executive_title                  ExecutiveTitle?
  engagement_type                  EngagementType                   @default(FULL_TIME)
  is_active                        Boolean                          @default(true)
  is_deleted                       Boolean                          @default(false)
  deleted_at                       DateTime?
  created_at                       DateTime                         @default(now())
  updated_at                       DateTime                         @updatedAt
  user                             User                             @relation(fields: [user_id], references: [id], onDelete: Cascade)
  organization                     Organization                     @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  roles                            ProfileRole[]
  branches                         ProfileBranch[]
  workingSchedules                 WorkingSchedule[]
  job_functions                    ProfileJobFunction[]
  specialty_links                  ProfileSpecialty[]
  created_journeys                 PatientJourney[]
  doctor_visits                    Visit[]                          @relation("DoctorVisits")
  created_visits                   Visit[]                          @relation("CreatedVisits")
  medications_added                Medication[]                     @relation("MedicationAddedBy")
  lab_tests_added                  LabTest[]                        @relation("LabTestAddedBy")
  vitals_recorded                  VisitVitals[]                    @relation("VitalsRecordedBy")
  investigations_ordered           VisitInvestigation[]             @relation("InvestigationOrderedBy")
  investigations_resulted          VisitInvestigation[]             @relation("InvestigationResultedBy")
  investigations_reviewed          VisitInvestigation[]             @relation("InvestigationReviewedBy")
  prescriptions_authored           Prescription[]                   @relation("PrescriptionPrescribedBy")
  history_notes_authored           PatientHistoryNote[]             @relation("HistoryNoteAuthor")
  authored_field_flags             PatientFieldFlag[]               @relation("FieldFlagAuthor")
  history_allergies_added          PatientAllergy[]                 @relation("AllergyCreatedBy")
  history_pregnancies_added        PatientPregnancyHistory[]        @relation("PregnancyCreatedBy")
  history_contraceptives_added     PatientContraceptiveHistory[]    @relation("ContraceptiveCreatedBy")
  history_surgeries_added          PatientNonGynSurgery[]           @relation("NonGynSurgeryCreatedBy")
  history_medications_added        PatientMedication[]              @relation("PatientMedicationCreatedBy")
  // Updated-by back-relations for clinical mutable rows that have a revision
  // shadow table (PR4). History sub-tables that are list-style records are
  // not versioned individually — their audit lives on the PatientObgynHistory
  // snapshot row.
  patient_obgyn_history_updates    PatientObgynHistory[]            @relation("PatientObgynHistoryUpdatedBy")
  visit_obgyn_encounter_updates    VisitObgynEncounter[]            @relation("VisitObgynEncounterUpdatedBy")
  pregnancy_journey_updates        PregnancyJourneyRecord[]         @relation("PregnancyJourneyRecordUpdatedBy")
  pregnancy_episode_updates        PregnancyEpisodeRecord[]         @relation("PregnancyEpisodeRecordUpdatedBy")
  visit_pregnancy_updates          VisitPregnancyRecord[]           @relation("VisitPregnancyRecordUpdatedBy")
  visit_encounter_updates          VisitEncounter[]                 @relation("VisitEncounterUpdatedBy")
  prescription_updates             Prescription[]                   @relation("PrescriptionUpdatedBy")
  prescription_item_updates        PrescriptionItem[]               @relation("PrescriptionItemUpdatedBy")
  investigation_updates            VisitInvestigation[]             @relation("VisitInvestigationUpdatedBy")
  // PR4: revision shadow tables — author back-relations
  patient_obgyn_history_revisions  PatientObgynHistoryRevision[]    @relation("PatientObgynHistoryRevisedBy")
  visit_encounter_revisions        VisitEncounterRevision[]         @relation("VisitEncounterRevisedBy")
  visit_obgyn_encounter_revisions  VisitObgynEncounterRevision[]    @relation("VisitObgynEncounterRevisedBy")
  prescription_revisions           PrescriptionRevision[]           @relation("PrescriptionRevisedBy")
  prescription_item_revisions      PrescriptionItemRevision[]       @relation("PrescriptionItemRevisedBy")
  pregnancy_journey_revisions      PregnancyJourneyRecordRevision[] @relation("PregnancyJourneyRecordRevisedBy")
  pregnancy_episode_revisions      PregnancyEpisodeRecordRevision[] @relation("PregnancyEpisodeRecordRevisedBy")
  visit_pregnancy_revisions        VisitPregnancyRecordRevision[]   @relation("VisitPregnancyRecordRevisedBy")
  // Builder / medical-rep back-relations
  form_templates_created           FormTemplate[]                   @relation("FormTemplateCreatedBy")
  form_templates_updated           FormTemplate[]                   @relation("FormTemplateUpdatedBy")
  medical_rep_visits_doctor        MedicalRepVisit[]                @relation("MedRepVisitDoctor")
  medical_rep_visits_created       MedicalRepVisit[]                @relation("MedRepVisitCreatedBy")
  calendar_events                  CalendarEvent[]                  @relation("CalendarEventProfile")
  calendar_event_assists           CalendarEventAssistant[]         @relation("CalendarEventAssistantProfile")
  notifications                    Notification[]
  // Financial back-relations
  services_created                 Service[]                        @relation("ServiceCreatedBy")
  price_lists_created              PriceList[]                      @relation("PriceListCreatedBy")
  price_list_items_created         PriceListItem[]                  @relation("PriceListItemCreatedBy")
  provider_services                ProviderService[]                @relation("ProfileProviderServices")
  provider_services_created        ProviderService[]                @relation("ProviderServiceCreatedBy")
  provider_price_overrides         ProviderPriceOverride[]          @relation("ProfilePriceOverrides")
  provider_price_overrides_created ProviderPriceOverride[]          @relation("ProviderPriceOverrideCreatedBy")
  invoices_created                 Invoice[]                        @relation("InvoiceCreatedBy")
  invoices_as_doctor               Invoice[]                        @relation("InvoiceDoctor")
  payments_recorded                Payment[]                        @relation("PaymentRecordedBy")
  refunds_issued                   Refund[]                         @relation("RefundedBy")

  @@unique([user_id, organization_id])
  @@index([organization_id, is_deleted])
  @@index([user_id, is_deleted])
  @@map("profiles")
}

model ProfileRole {
  id         String   @id @default(uuid()) @db.Uuid
  profile_id String   @db.Uuid
  role_id    String   @db.Uuid
  created_at DateTime @default(now())
  profile    Profile  @relation(fields: [profile_id], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [role_id], references: [id], onDelete: Cascade)

  @@unique([profile_id, role_id])
  @@index([role_id])
  @@map("profile_roles")
}

model ProfileBranch {
  id              String   @id @default(uuid()) @db.Uuid
  profile_id      String   @db.Uuid
  branch_id       String   @db.Uuid
  organization_id String   @db.Uuid
  created_at      DateTime @default(now())
  profile         Profile  @relation(fields: [profile_id], references: [id], onDelete: Cascade)
  branch          Branch   @relation(fields: [branch_id, organization_id], references: [id, organization_id], onDelete: Cascade)

  @@unique([profile_id, branch_id])
  @@index([organization_id, branch_id])
  @@map("profile_branches")
}

model Subscription {
  id                   String             @id @default(uuid()) @db.Uuid
  organization_id      String             @db.Uuid
  subscription_plan_id String             @db.Uuid
  status               SubscriptionStatus @default(TRIAL)
  starts_at            DateTime           @default(now())
  ends_at              DateTime?
  trial_ends_at        DateTime?
  created_at           DateTime           @default(now())
  updated_at           DateTime           @updatedAt
  is_deleted           Boolean            @default(false)
  deleted_at           DateTime?
  organization         Organization       @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  subscription_plan    SubscriptionPlan   @relation(fields: [subscription_plan_id], references: [id])

  @@index([organization_id, is_deleted])
  @@map("subscriptions")
}

model RefreshToken {
  id               String    @id @default(uuid()) @db.Uuid
  jti              String    @unique @db.Uuid
  token_hash       String
  user_id          String    @db.Uuid
  profile_id       String?   @db.Uuid
  organization_id  String?   @db.Uuid
  active_branch_id String?   @db.Uuid
  expires_at       DateTime
  is_revoked       Boolean   @default(false)
  revoked_at       DateTime?
  created_at       DateTime  @default(now())
  user             User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, is_revoked])
  @@map("refresh_tokens")
}

// Audit trail for AUTH_EVENTS. Written by AuthAuditListener on every
// signup.completed / login.succeeded / login.failed /
// password_reset.completed / refresh.rotated event. Independent of
// rest of the request flow: a write failure must NOT bubble up and
// fail the user-facing action.
model AuthAuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  event_name String
  user_id    String?  @db.Uuid
  email      String?
  payload    Json
  at         DateTime
  created_at DateTime @default(now())
  user       User?    @relation(fields: [user_id], references: [id], onDelete: SetNull)

  @@index([user_id, created_at])
  @@index([event_name, created_at])
  @@map("auth_audit_log")
}

// Tracks reset tokens AFTER the verify step issues a verified token.
// PasswordResetService.verify writes one row; reset() looks the row up by
// jti and rejects re-use via consumed_at. Forgot-password.start does NOT
// write a row — synthesized tokens for unknown emails have no underlying
// user and the verify step short-circuits with INVALID_CODE before this
// table is touched, so symmetry with the real-but-wrong-code path holds.
model PasswordResetToken {
  id          String    @id @default(uuid()) @db.Uuid
  jti         String    @unique @db.Uuid
  user_id     String    @db.Uuid
  target      String
  expires_at  DateTime
  consumed_at DateTime?
  created_at  DateTime  @default(now())
  user        User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("password_reset_tokens")
}

model VerificationCode {
  id           String              @id @default(uuid()) @db.Uuid
  user_id      String?             @db.Uuid
  channel      VerificationChannel
  purpose      VerificationPurpose
  target       String
  code_hash    String
  attempts     Int                 @default(0)
  max_attempts Int                 @default(5)
  is_resend    Boolean             @default(false)
  expires_at   DateTime
  consumed_at  DateTime?
  created_at   DateTime            @default(now())
  user         User?               @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([target, purpose, consumed_at])
  @@index([user_id, purpose])
  @@map("verification_codes")
}

model Invitation {
  id              String                  @id @default(uuid()) @db.Uuid
  organization_id String                  @db.Uuid
  invited_by_id   String                  @db.Uuid
  email           String
  first_name      String
  last_name       String
  phone_number    String?
  executive_title ExecutiveTitle?
  engagement_type EngagementType          @default(FULL_TIME)
  token_hash      String                  @unique
  status          InvitationStatus        @default(PENDING)
  expires_at      DateTime
  accepted_at     DateTime?
  is_deleted      Boolean                 @default(false)
  deleted_at      DateTime?
  created_at      DateTime                @default(now())
  updated_at      DateTime                @updatedAt
  organization    Organization            @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  invited_by      User                    @relation("InvitedBy", fields: [invited_by_id], references: [id])
  roles           InvitationRole[]
  branches        InvitationBranch[]
  job_functions   InvitationJobFunction[]
  specialty_links InvitationSpecialty[]

  @@index([organization_id, status])
  @@index([email])
  @@index([expires_at])
  @@index([status, expires_at])
  // Partial unique index `invitations_org_email_pending_unique` added via raw
  // SQL in the `invitations_hardening` migration (Prisma cannot express
  // partial unique indexes natively).
  @@map("invitations")
}

model InvitationRole {
  id            String     @id @default(uuid()) @db.Uuid
  invitation_id String     @db.Uuid
  role_id       String     @db.Uuid
  created_at    DateTime   @default(now())
  invitation    Invitation @relation(fields: [invitation_id], references: [id], onDelete: Cascade)
  role          Role       @relation(fields: [role_id], references: [id], onDelete: Cascade)

  @@unique([invitation_id, role_id])
  @@map("invitation_roles")
}

model InvitationBranch {
  id              String     @id @default(uuid()) @db.Uuid
  invitation_id   String     @db.Uuid
  branch_id       String     @db.Uuid
  organization_id String     @db.Uuid
  created_at      DateTime   @default(now())
  invitation      Invitation @relation(fields: [invitation_id], references: [id], onDelete: Cascade)
  branch          Branch     @relation(fields: [branch_id, organization_id], references: [id, organization_id], onDelete: Cascade)

  @@unique([invitation_id, branch_id])
  @@index([organization_id, branch_id])
  @@map("invitation_branches")
}

model Notification {
  id          String    @id @default(uuid()) @db.Uuid
  // Notifications are scoped to a Profile (org membership), not a User. A person
  // with profiles in several orgs gets a distinct inbox per org — `navigate_to`
  // links resolve within that org's context.
  profile_id  String    @db.Uuid
  // Stable machine key drawn from the catalog at
  // @core/notifications/notification-codes.ts. `category` is the display label.
  code        String
  category    String
  title       String
  description String
  navigate_to String?
  is_read     Boolean   @default(false)
  read_at     DateTime?
  metadata    Json?
  is_deleted  Boolean   @default(false)
  deleted_at  DateTime?
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
  profile     Profile   @relation(fields: [profile_id], references: [id], onDelete: Cascade)

  @@index([profile_id, is_read, is_deleted])
  @@index([profile_id, category, is_deleted])
  @@index([profile_id, code, is_deleted])
  @@map("notifications")
}

model WorkingSchedule {
  id         String       @id @default(uuid()) @db.Uuid
  profile_id String       @db.Uuid
  branch_id  String       @db.Uuid
  created_at DateTime     @default(now())
  updated_at DateTime     @updatedAt
  profile    Profile      @relation(fields: [profile_id], references: [id], onDelete: Cascade)
  branch     Branch       @relation(fields: [branch_id], references: [id], onDelete: Cascade)
  days       WorkingDay[]

  @@unique([profile_id, branch_id])
  @@index([profile_id])
  @@map("working_schedules")
}

model WorkingDay {
  id          String          @id @default(uuid()) @db.Uuid
  schedule_id String          @db.Uuid
  day_of_week DayOfWeek
  created_at  DateTime        @default(now())
  schedule    WorkingSchedule @relation(fields: [schedule_id], references: [id], onDelete: Cascade)
  shifts      WorkingShift[]

  @@unique([schedule_id, day_of_week])
  @@map("working_days")
}

model WorkingShift {
  id           String     @id @default(uuid()) @db.Uuid
  day_id       String     @db.Uuid
  // Minutes from midnight. 0..1439 for start, 1..1440 for end, end > start.
  // CHECK constraints enforced in the `working_shift_minutes` migration.
  start_minute Int
  end_minute   Int
  created_at   DateTime   @default(now())
  day          WorkingDay @relation(fields: [day_id], references: [id], onDelete: Cascade)

  @@map("working_shifts")
}

model Specialty {
  id                  String                  @id @default(uuid()) @db.Uuid
  name                String                  @unique
  code                String                  @unique
  description         String?
  templates           JourneyTemplate[]
  care_paths          CarePath[]
  procedures          Procedure[]
  profile_links       ProfileSpecialty[]
  org_links           OrganizationSpecialty[]
  inv_links           InvitationSpecialty[]
  lab_tests           LabTest[]
  form_templates      FormTemplate[]
  service_specialties ServiceSpecialty[]      @relation("SpecialtyServices")
  created_at          DateTime                @default(now())
  updated_at          DateTime                @updatedAt
  is_deleted          Boolean                 @default(false)
  deleted_at          DateTime?

  @@map("specialties")
}

model Procedure {
  id           String    @id @default(uuid()) @db.Uuid
  specialty_id String    @db.Uuid
  name         String
  code         String    @unique
  description  String?
  specialty    Specialty @relation(fields: [specialty_id], references: [id], onDelete: Cascade)
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt
