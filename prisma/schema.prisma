  created_at      DateTime     @default(now())
  profile         Profile      @relation(fields: [profile_id], references: [id], onDelete: Cascade)
  subspecialty    Subspecialty @relation(fields: [subspecialty_id], references: [id], onDelete: Cascade)

  @@unique([profile_id, subspecialty_id])
  @@index([subspecialty_id])
  @@map("profile_subspecialties")
}

model OrganizationSpecialty {
  id              String       @id @default(uuid()) @db.Uuid
