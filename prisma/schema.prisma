generator client {
  provider = "prisma-client-js"
}

generator dbml {
  provider = "prisma-dbml-generator"
}

datasource db {
  provider = "postgresql"
}

enum RegistrationStatus {
  PENDING
  ACTIVE
}

enum OrganizationStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum BranchStatus {
  ACTIVE
  INACTIVE
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  EXPIRED
  CANCELLED
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  CANCELLED
}

enum DayOfWeek {
  MON
  TUE
  WED
  THU
  FRI
  SAT
  SUN
}

enum VerificationChannel {
  EMAIL
}

enum VerificationPurpose {
  SIGNUP
  LOGIN
  PASSWORD_RESET
}

enum JourneyTemplateType {
  PREGNANCY
  GENERAL_GYN
  SURGICAL
  CHRONIC_CONDITION
}

enum JourneyStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum EpisodeStatus {
  PENDING
  ACTIVE
  COMPLETED
}

enum VisitType {
  INITIAL
  FOLLOW_UP
  ROUTINE
  EMERGENCY
  PROCEDURE
}

enum VisitPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum VisitStatus {
  SCHEDULED
  CHECKED_IN
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

model SubscriptionPlan {
  id                String         @id @default(uuid()) @db.Uuid
  plan              String         @unique
  max_organizations Int
  max_branches      Int
  max_staff         Int
  created_at        DateTime       @default(now())
  updated_at        DateTime       @updatedAt
  subscriptions     Subscription[]

  @@map("subscription_plans")
}

model Organization {
  id               String             @id @default(uuid()) @db.Uuid
  name             String
  specialities     String[]           @default([])
  status           OrganizationStatus @default(ACTIVE)
  is_deleted       Boolean            @default(false)
  deleted_at       DateTime?
  created_at       DateTime           @default(now())
  updated_at       DateTime           @updatedAt
  branches         Branch[]
  profiles         Profile[]
  invitations      Invitation[]
  subscriptions    Subscription[]
  patient_journeys PatientJourney[]

  @@index([status, is_deleted])
  @@map("organizations")
}

model Branch {
  id                 String             @id @default(uuid()) @db.Uuid
  name               String
  address            String
  city               String
  governorate        String
  country            String?
  is_main            Boolean            @default(false)
  status             BranchStatus       @default(ACTIVE)
  is_deleted         Boolean            @default(false)
  deleted_at         DateTime?
  created_at         DateTime           @default(now())
  updated_at         DateTime           @updatedAt
  organization_id    String             @db.Uuid
  organization       Organization       @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  profileBranches    ProfileBranch[]
  invitationBranches InvitationBranch[]
  workingSchedules   WorkingSchedule[]
  visits             Visit[]

  @@unique([id, organization_id])
  @@index([organization_id, is_deleted])
  @@map("branches")
}

model User {
  id                   String             @id @default(uuid()) @db.Uuid
  first_name           String
  last_name            String
  email                String?            @unique
  phone_number         String?
  password_hashed      String?
  is_active            Boolean            @default(true)
  is_deleted           Boolean            @default(false)
  deleted_at           DateTime?
  verified_at          DateTime?
  registration_status  RegistrationStatus @default(PENDING)
  onboarding_completed Boolean            @default(false)
  created_at           DateTime           @default(now())
  updated_at           DateTime           @updatedAt
  profiles             Profile[]
  refreshTokens        RefreshToken[]
  verificationCodes    VerificationCode[]
  sentInvitations      Invitation[]       @relation("InvitedBy")
  notifications        Notification[]

  @@index([registration_status, onboarding_completed])
  @@map("users")
}

model Role {
  id              String           @id @default(uuid()) @db.Uuid
  name            String           @unique
  created_at      DateTime         @default(now())
  updated_at      DateTime         @updatedAt
  profileRoles    ProfileRole[]
  invitationRoles InvitationRole[]

  @@map("roles")
}

model Profile {
  id               String            @id @default(uuid()) @db.Uuid
  user_id          String            @db.Uuid
  organization_id  String            @db.Uuid
  job_title        String?
  specialty        String?
  is_clinical      Boolean           @default(false)
  is_active        Boolean           @default(true)
  is_deleted       Boolean           @default(false)
  deleted_at       DateTime?
  created_at       DateTime          @default(now())
  updated_at       DateTime          @updatedAt
  user             User              @relation(fields: [user_id], references: [id], onDelete: Cascade)
  organization     Organization      @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  roles            ProfileRole[]
  branches         ProfileBranch[]
  workingSchedules WorkingSchedule[]
  created_journeys PatientJourney[]
  doctor_visits    Visit[]           @relation("DoctorVisits")
  created_visits   Visit[]           @relation("CreatedVisits")

  @@unique([user_id, organization_id])
  @@index([organization_id, is_deleted])
  @@index([user_id, is_deleted])
  @@map("profiles")
}

model ProfileRole {
  id         String   @id @default(uuid()) @db.Uuid
  profile_id String   @db.Uuid
  role_id    String   @db.Uuid
  created_at DateTime @default(now())
  profile    Profile  @relation(fields: [profile_id], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [role_id], references: [id], onDelete: Cascade)

  @@unique([profile_id, role_id])
  @@index([role_id])
  @@map("profile_roles")
}

model ProfileBranch {
  id              String   @id @default(uuid()) @db.Uuid
  profile_id      String   @db.Uuid
  branch_id       String   @db.Uuid
  organization_id String   @db.Uuid
  created_at      DateTime @default(now())
  profile         Profile  @relation(fields: [profile_id], references: [id], onDelete: Cascade)
  branch          Branch   @relation(fields: [branch_id, organization_id], references: [id, organization_id], onDelete: Cascade)

  @@unique([profile_id, branch_id])
  @@index([organization_id, branch_id])
  @@map("profile_branches")
}

model Subscription {
  id                   String             @id @default(uuid()) @db.Uuid
  organization_id      String             @db.Uuid
  subscription_plan_id String             @db.Uuid
  status               SubscriptionStatus @default(TRIAL)
  starts_at            DateTime           @default(now())
  ends_at              DateTime?
  trial_ends_at        DateTime?
  created_at           DateTime           @default(now())
  updated_at           DateTime           @updatedAt
  is_deleted           Boolean            @default(false)
  deleted_at           DateTime?
  organization         Organization       @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  subscription_plan    SubscriptionPlan   @relation(fields: [subscription_plan_id], references: [id])

  @@index([organization_id, is_deleted])
  @@map("subscriptions")
}

model RefreshToken {
  id               String    @id @default(uuid()) @db.Uuid
  jti              String    @unique @db.Uuid
  token_hash       String
  user_id          String    @db.Uuid
  profile_id       String?   @db.Uuid
  organization_id  String?   @db.Uuid
  active_branch_id String?   @db.Uuid
  expires_at       DateTime
  is_revoked       Boolean   @default(false)
  revoked_at       DateTime?
  created_at       DateTime  @default(now())
  user             User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, is_revoked])
  @@map("refresh_tokens")
}

model VerificationCode {
  id           String              @id @default(uuid()) @db.Uuid
  user_id      String?             @db.Uuid
  channel      VerificationChannel
  purpose      VerificationPurpose
  target       String
  code_hash    String
  attempts     Int                 @default(0)
  max_attempts Int                 @default(5)
  is_resend    Boolean             @default(false)
  expires_at   DateTime
  consumed_at  DateTime?
  created_at   DateTime            @default(now())
  user         User?               @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([target, purpose, consumed_at])
  @@index([user_id, purpose])
  @@map("verification_codes")
}

model Invitation {
  id              String             @id @default(uuid()) @db.Uuid
  organization_id String             @db.Uuid
  invited_by_id   String             @db.Uuid
  email           String
  first_name      String
  last_name       String
  phone_number    String?
  job_title       String?
  specialty       String?
  is_clinical     Boolean            @default(false)
  token_hash      String
  status          InvitationStatus   @default(PENDING)
  expires_at      DateTime
  accepted_at     DateTime?
  is_deleted      Boolean            @default(false)
  deleted_at      DateTime?
  created_at      DateTime           @default(now())
  updated_at      DateTime           @updatedAt
  organization    Organization       @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  invited_by      User               @relation("InvitedBy", fields: [invited_by_id], references: [id])
  roles           InvitationRole[]
  branches        InvitationBranch[]

  @@index([organization_id, status])
  @@index([email])
  @@index([expires_at])
  @@map("invitations")
}

model InvitationRole {
  id            String     @id @default(uuid()) @db.Uuid
  invitation_id String     @db.Uuid
  role_id       String     @db.Uuid
  created_at    DateTime   @default(now())
  invitation    Invitation @relation(fields: [invitation_id], references: [id], onDelete: Cascade)
  role          Role       @relation(fields: [role_id], references: [id], onDelete: Cascade)

  @@unique([invitation_id, role_id])
  @@map("invitation_roles")
}

model InvitationBranch {
  id              String     @id @default(uuid()) @db.Uuid
  invitation_id   String     @db.Uuid
  branch_id       String     @db.Uuid
  organization_id String     @db.Uuid
  created_at      DateTime   @default(now())
  invitation      Invitation @relation(fields: [invitation_id], references: [id], onDelete: Cascade)
  branch          Branch     @relation(fields: [branch_id, organization_id], references: [id, organization_id], onDelete: Cascade)

  @@unique([invitation_id, branch_id])
  @@index([organization_id, branch_id])
  @@map("invitation_branches")
}

model Notification {
  id          String    @id @default(uuid()) @db.Uuid
  user_id     String    @db.Uuid
  category    String
  title       String
  description String
  navigate_to String?
  is_read     Boolean   @default(false)
  read_at     DateTime?
  metadata    Json?
  is_deleted  Boolean   @default(false)
  deleted_at  DateTime?
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
  user        User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, is_read, is_deleted])
  @@index([user_id, category, is_deleted])
  @@map("notifications")
}

model WorkingSchedule {
  id         String       @id @default(uuid()) @db.Uuid
  profile_id String       @db.Uuid
  branch_id  String       @db.Uuid
  created_at DateTime     @default(now())
  updated_at DateTime     @updatedAt
  profile    Profile      @relation(fields: [profile_id], references: [id], onDelete: Cascade)
  branch     Branch       @relation(fields: [branch_id], references: [id], onDelete: Cascade)
  days       WorkingDay[]

  @@unique([profile_id, branch_id])
  @@index([profile_id])
  @@map("working_schedules")
}

model WorkingDay {
  id          String          @id @default(uuid()) @db.Uuid
  schedule_id String          @db.Uuid
  day_of_week DayOfWeek
  created_at  DateTime        @default(now())
  schedule    WorkingSchedule @relation(fields: [schedule_id], references: [id], onDelete: Cascade)
  shifts      WorkingShift[]

  @@unique([schedule_id, day_of_week])
  @@map("working_days")
}

model WorkingShift {
  id         String     @id @default(uuid()) @db.Uuid
  day_id     String     @db.Uuid
  start_time String
  end_time   String
  created_at DateTime   @default(now())
  day        WorkingDay @relation(fields: [day_id], references: [id], onDelete: Cascade)

  @@map("working_shifts")
}

model Specialty {
  id          String            @id @default(uuid()) @db.Uuid
  name        String            @unique
  code        String            @unique
  description String?
  templates   JourneyTemplate[]
  created_at  DateTime          @default(now())
  updated_at  DateTime          @updatedAt
  is_deleted  Boolean           @default(false)
  deleted_at  DateTime?

  @@map("specialties")
}

model JourneyTemplate {
  id           String              @id @default(uuid()) @db.Uuid
  specialty_id String              @db.Uuid
  specialty    Specialty           @relation(fields: [specialty_id], references: [id], onDelete: Cascade)
  name         String              @unique
  type         JourneyTemplateType
  description  String?
  episodes     EpisodeTemplate[]
  journeys     PatientJourney[]
  created_at   DateTime            @default(now())
  updated_at   DateTime            @updatedAt
  is_deleted   Boolean             @default(false)
  deleted_at   DateTime?

  @@index([specialty_id])
  @@map("journey_templates")
}

model EpisodeTemplate {
  id                  String           @id @default(uuid()) @db.Uuid
  journey_template_id String           @db.Uuid
  journey_template    JourneyTemplate  @relation(fields: [journey_template_id], references: [id], onDelete: Cascade)
  name                String
  order               Int
  episodes            PatientEpisode[]
  created_at          DateTime         @default(now())
  updated_at          DateTime         @updatedAt
  is_deleted          Boolean          @default(false)
  deleted_at          DateTime?

  @@index([journey_template_id])
  @@map("episode_templates")
}

model Patient {
  id            String           @id @default(uuid()) @db.Uuid
  national_id   String           @unique
  full_name     String
  husband_name  String?
  date_of_birth DateTime         @db.Date
  phone_number  String
  address       String
  journeys      PatientJourney[]
  created_at    DateTime         @default(now())
  updated_at    DateTime         @updatedAt
  is_deleted    Boolean          @default(false)
  deleted_at    DateTime?

  @@map("patients")
}

model PatientJourney {
  id                  String           @id @default(uuid()) @db.Uuid
  patient_id          String           @db.Uuid
  patient             Patient          @relation(fields: [patient_id], references: [id], onDelete: Cascade)
  organization_id     String           @db.Uuid
  organization        Organization     @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  journey_template_id String           @db.Uuid
  journey_template    JourneyTemplate  @relation(fields: [journey_template_id], references: [id], onDelete: Cascade)
  created_by_id       String           @db.Uuid
  created_by          Profile          @relation(fields: [created_by_id], references: [id], onDelete: Cascade)
  status              JourneyStatus    @default(ACTIVE)
  started_at          DateTime         @default(now())
  ended_at            DateTime?
  episodes            PatientEpisode[]
  created_at          DateTime         @default(now())
  updated_at          DateTime         @updatedAt
  is_deleted          Boolean          @default(false)
  deleted_at          DateTime?

  @@index([patient_id, organization_id, is_deleted])
  @@index([organization_id, status, is_deleted])
  @@map("patient_journeys")
}

model PatientEpisode {
  id                  String          @id @default(uuid()) @db.Uuid
  journey_id          String          @db.Uuid
  journey             PatientJourney  @relation(fields: [journey_id], references: [id], onDelete: Cascade)
  episode_template_id String          @db.Uuid
  episode_template    EpisodeTemplate @relation(fields: [episode_template_id], references: [id], onDelete: Cascade)
  name                String
  order               Int
  status              EpisodeStatus   @default(PENDING)
  started_at          DateTime?
  ended_at            DateTime?
  visits              Visit[]
  created_at          DateTime        @default(now())
  updated_at          DateTime        @updatedAt
  is_deleted          Boolean         @default(false)
  deleted_at          DateTime?

  @@index([journey_id, is_deleted])
  @@map("patient_episodes")
}

model Visit {
  id                 String         @id @default(uuid()) @db.Uuid
  episode_id         String         @db.Uuid
  episode            PatientEpisode @relation(fields: [episode_id], references: [id], onDelete: Cascade)
  assigned_doctor_id String         @db.Uuid
  assigned_doctor    Profile        @relation("DoctorVisits", fields: [assigned_doctor_id], references: [id], onDelete: Cascade)
  branch_id          String         @db.Uuid
  branch             Branch         @relation(fields: [branch_id], references: [id], onDelete: Cascade)
  created_by_id      String         @db.Uuid
  created_by         Profile        @relation("CreatedVisits", fields: [created_by_id], references: [id], onDelete: Cascade)
  visit_type         VisitType
  priority           VisitPriority
  status             VisitStatus    @default(SCHEDULED)
  scheduled_at       DateTime
  checked_in_at      DateTime?
  started_at         DateTime?
  completed_at       DateTime?
  notes              String?
  created_at         DateTime       @default(now())
  updated_at         DateTime       @updatedAt
  is_deleted         Boolean        @default(false)
  deleted_at         DateTime?

  @@index([episode_id, is_deleted])
  @@index([assigned_doctor_id, is_deleted])
  @@index([branch_id, status, is_deleted])
  @@map("visits")
}
