generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model SubscriptionPlan {
  id            String         @id @default(uuid()) @db.Uuid
  plan          String
  max_branches  Int
  max_staff     Int
  created_at    DateTime       @default(now())
  updated_at    DateTime       @updatedAt
  subscriptions Subscription[]

  @@map("subscription_plans")
}

model Organization {
  id            String         @id @default(uuid()) @db.Uuid
  name          String
  specialities  String[]
  status        String
  is_deleted    Boolean        @default(false)
  deleted_at    DateTime?
  created_at    DateTime       @default(now())
  updated_at    DateTime       @updatedAt
  branches      Branch[]
  staff         Staff[]
  subscriptions Subscription[]

  @@map("organizations")
}

model Branch {
  id              String       @id @default(uuid()) @db.Uuid
  address         String
  city            String
  governate       String
  is_main         Boolean      @default(false)
  status          String
  is_deleted      Boolean      @default(false)
  deleted_at      DateTime?
  created_at      DateTime     @default(now())
  updated_at      DateTime     @updatedAt
  organization_id String       @db.Uuid
  organization    Organization @relation(fields: [organization_id], references: [id])
  staff           Staff[]

  @@unique([id, organization_id])
  @@map("branches")
}

model User {
  id              String    @id @default(uuid()) @db.Uuid
  first_name      String
  last_name       String
  email           String    @unique
  password_hashed String
  is_active       Boolean   @default(true)
  is_deleted      Boolean   @default(false)
  deleted_at      DateTime?
  verified_at     DateTime?
  created_at      DateTime  @default(now())
  profile         Profile?
  staff           Staff[]

  @@map("users")
}

model Role {
  id         String   @id @default(uuid()) @db.Uuid
  name       String   @unique
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  staff      Staff[]

  @@map("roles")
}

model Profile {
  id          String    @id @default(uuid()) @db.Uuid
  is_clinical Boolean   @default(false)
  speciality  String?
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
  is_deleted  Boolean   @default(false)
  deleted_at  DateTime?
  user_id     String    @unique @db.Uuid
  user        User      @relation(fields: [user_id], references: [id])

  @@map("profiles")
}

model Staff {
  id              String       @id @default(uuid()) @db.Uuid
  user_id         String       @db.Uuid
  organization_id String       @db.Uuid
  branch_id       String       @db.Uuid
  role_id         String       @db.Uuid
  created_at      DateTime     @default(now())
  updated_at      DateTime     @updatedAt
  is_deleted      Boolean      @default(false)
  deleted_at      DateTime?
  user            User         @relation(fields: [user_id], references: [id])
  organization    Organization @relation(fields: [organization_id], references: [id])
  branch          Branch       @relation(fields: [branch_id, organization_id], references: [id, organization_id])
  role            Role         @relation(fields: [role_id], references: [id])

  @@unique([user_id, organization_id, branch_id, role_id])
  @@map("staff")
}

model Subscription {
  id                   String           @id @default(uuid()) @db.Uuid
  organization_id      String           @db.Uuid
  subscription_plan_id String           @db.Uuid
  created_at           DateTime         @default(now())
  updated_at           DateTime         @updatedAt
  is_deleted           Boolean          @default(false)
  deleted_at           DateTime?
  organization         Organization     @relation(fields: [organization_id], references: [id])
  subscription_plan    SubscriptionPlan @relation(fields: [subscription_plan_id], references: [id])

  @@map("subscriptions")
}
