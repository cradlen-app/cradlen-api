generator client {
  provider = "prisma-client-js"
}

generator dbml {
  provider = "prisma-dbml-generator"
}

datasource db {
  provider = "postgresql"
}

enum RegistrationStatus {
  PENDING
  ACTIVE
}

enum OrganizationStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum BranchStatus {
  ACTIVE
  INACTIVE
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  EXPIRED
  CANCELLED
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  CANCELLED
}

enum DayOfWeek {
  MON
  TUE
  WED
  THU
  FRI
  SAT
  SUN
}

enum VerificationChannel {
  EMAIL
}

enum VerificationPurpose {
  SIGNUP
  LOGIN
  PASSWORD_RESET
}

enum JourneyTemplateType {
  PREGNANCY
  GENERAL_GYN
  SURGICAL
  CHRONIC_CONDITION
}

enum JourneyStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum EpisodeStatus {
  PENDING
  ACTIVE
  COMPLETED
}

enum VisitType {
  VISIT
  FOLLOW_UP
  MEDICAL_REP
}

enum VisitPriority {
  NORMAL
  EMERGENCY
}

enum VisitStatus {
  SCHEDULED
  CHECKED_IN
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum ExecutiveTitle {
  CEO
  COO
  CFO
  CMO
}

enum EngagementType {
  FULL_TIME
  PART_TIME
  ON_DEMAND
  EXTERNAL_CONSULTANT
}

enum LabTestCategory {
  LAB
  IMAGING
  OTHER
}

enum InvestigationStatus {
  ORDERED
  RESULTED
  REVIEWED
  CANCELLED
}

enum InvestigationResultSource {
  CLINIC
  PATIENT
  EXTERNAL_LAB
}

enum PatientHistorySection {
  MENSTRUAL
  GYNECOLOGIC_PROCEDURES
  CONTRACEPTIVE
  SCREENING
  OBSTETRIC
  MEDICAL
  FAMILY
  FERTILITY
}

enum NoteVisibility {
  PRIVATE_TO_ORG
  SHARED_GLOBAL
}

model SubscriptionPlan {
  id                String         @id @default(uuid()) @db.Uuid
  plan              String         @unique
  max_organizations Int
  max_branches      Int
  max_staff         Int
  created_at        DateTime       @default(now())
  updated_at        DateTime       @updatedAt
  subscriptions     Subscription[]

  @@map("subscription_plans")
}

model Organization {
  id                    String                  @id @default(uuid()) @db.Uuid
  name                  String
  status                OrganizationStatus      @default(ACTIVE)
  is_deleted            Boolean                 @default(false)
  deleted_at            DateTime?
  created_at            DateTime                @default(now())
  updated_at            DateTime                @updatedAt
  branches              Branch[]
  profiles              Profile[]
  invitations           Invitation[]
  subscriptions         Subscription[]
  patient_journeys      PatientJourney[]
  specialty_links       OrganizationSpecialty[]
  medications           Medication[]
  lab_tests             LabTest[]
  patient_history_notes PatientHistoryNote[]
  care_paths            CarePath[]
  care_path_episodes    CarePathEpisode[]

  @@index([status, is_deleted])
  @@map("organizations")
}

model Branch {
  id                 String             @id @default(uuid()) @db.Uuid
  name               String
  address            String
  city               String
  governorate        String
  country            String?
  is_main            Boolean            @default(false)
  status             BranchStatus       @default(ACTIVE)
  is_deleted         Boolean            @default(false)
  deleted_at         DateTime?
  created_at         DateTime           @default(now())
  updated_at         DateTime           @updatedAt
  organization_id    String             @db.Uuid
  organization       Organization       @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  profileBranches    ProfileBranch[]
  invitationBranches InvitationBranch[]
  workingSchedules   WorkingSchedule[]
  visits             Visit[]

  @@unique([id, organization_id])
  @@index([organization_id, is_deleted])
  @@map("branches")
}

model User {
  id                   String             @id @default(uuid()) @db.Uuid
  first_name           String
  last_name            String
  email                String?            @unique
  phone_number         String?
  password_hashed      String?
  is_active            Boolean            @default(true)
  is_deleted           Boolean            @default(false)
  deleted_at           DateTime?
  verified_at          DateTime?
  registration_status  RegistrationStatus @default(PENDING)
  onboarding_completed Boolean            @default(false)
  created_at           DateTime           @default(now())
  updated_at           DateTime           @updatedAt
  profiles             Profile[]
  refreshTokens        RefreshToken[]
  verificationCodes    VerificationCode[]
  sentInvitations      Invitation[]       @relation("InvitedBy")
  notifications        Notification[]

  @@index([registration_status, onboarding_completed])
  @@map("users")
}

model Role {
  id              String           @id @default(uuid()) @db.Uuid
  name            String           @unique
  created_at      DateTime         @default(now())
  updated_at      DateTime         @updatedAt
  profileRoles    ProfileRole[]
  invitationRoles InvitationRole[]

  @@map("roles")
}

model JobFunction {
  id               String                  @id @default(uuid()) @db.Uuid
  name             String                  @unique
  code             String                  @unique
  is_clinical      Boolean                 @default(false)
  created_at       DateTime                @default(now())
  updated_at       DateTime                @updatedAt
  profile_links    ProfileJobFunction[]
  invitation_links InvitationJobFunction[]

  @@map("job_functions")
}

model ProfileJobFunction {
  id              String      @id @default(uuid()) @db.Uuid
  profile_id      String      @db.Uuid
  job_function_id String      @db.Uuid
  created_at      DateTime    @default(now())
  profile         Profile     @relation(fields: [profile_id], references: [id], onDelete: Cascade)
  job_function    JobFunction @relation(fields: [job_function_id], references: [id], onDelete: Cascade)

  @@unique([profile_id, job_function_id])
  @@index([job_function_id])
  @@map("profile_job_functions")
}

model Profile {
  id                            String                        @id @default(uuid()) @db.Uuid
  user_id                       String                        @db.Uuid
  organization_id               String                        @db.Uuid
  executive_title               ExecutiveTitle?
  engagement_type               EngagementType                @default(FULL_TIME)
  is_active                     Boolean                       @default(true)
  is_deleted                    Boolean                       @default(false)
  deleted_at                    DateTime?
  created_at                    DateTime                      @default(now())
  updated_at                    DateTime                      @updatedAt
  user                          User                          @relation(fields: [user_id], references: [id], onDelete: Cascade)
  organization                  Organization                  @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  roles                         ProfileRole[]
  branches                      ProfileBranch[]
  workingSchedules              WorkingSchedule[]
  job_functions                 ProfileJobFunction[]
  specialty_links               ProfileSpecialty[]
  created_journeys              PatientJourney[]
  doctor_visits                 Visit[]                       @relation("DoctorVisits")
  created_visits                Visit[]                       @relation("CreatedVisits")
  medications_added             Medication[]                  @relation("MedicationAddedBy")
  lab_tests_added               LabTest[]                     @relation("LabTestAddedBy")
  vitals_recorded               VisitVitals[]                 @relation("VitalsRecordedBy")
  investigations_ordered        VisitInvestigation[]          @relation("InvestigationOrderedBy")
  investigations_resulted       VisitInvestigation[]          @relation("InvestigationResultedBy")
  investigations_reviewed       VisitInvestigation[]          @relation("InvestigationReviewedBy")
  prescriptions_authored        Prescription[]                @relation("PrescriptionPrescribedBy")
  history_notes_authored        PatientHistoryNote[]          @relation("HistoryNoteAuthor")
  history_allergies_added       PatientAllergy[]              @relation("AllergyCreatedBy")
  history_pregnancies_added     PatientPregnancyHistory[]     @relation("PregnancyCreatedBy")
  history_contraceptives_added  PatientContraceptiveHistory[] @relation("ContraceptiveCreatedBy")
  history_surgeries_added       PatientNonGynSurgery[]        @relation("NonGynSurgeryCreatedBy")
  history_medications_added     PatientMedication[]           @relation("PatientMedicationCreatedBy")
  // Updated-by back-relations (audit trail; PR4 will use these via revision shadow tables)
  history_notes_updated         PatientHistoryNote[]          @relation("HistoryNoteUpdatedBy")
  patient_obgyn_history_updates PatientObgynHistory[]         @relation("PatientObgynHistoryUpdatedBy")
  visit_obgyn_encounter_updates VisitObgynEncounter[]         @relation("VisitObgynEncounterUpdatedBy")
  pregnancy_journey_updates     PregnancyJourneyRecord[]      @relation("PregnancyJourneyRecordUpdatedBy")
  pregnancy_episode_updates     PregnancyEpisodeRecord[]      @relation("PregnancyEpisodeRecordUpdatedBy")
  visit_pregnancy_updates       VisitPregnancyRecord[]        @relation("VisitPregnancyRecordUpdatedBy")
  visit_encounter_updates       VisitEncounter[]              @relation("VisitEncounterUpdatedBy")
  prescription_updates          Prescription[]                @relation("PrescriptionUpdatedBy")
  prescription_item_updates     PrescriptionItem[]            @relation("PrescriptionItemUpdatedBy")
  investigation_updates         VisitInvestigation[]          @relation("VisitInvestigationUpdatedBy")
  pregnancy_history_updates     PatientPregnancyHistory[]     @relation("PatientPregnancyHistoryUpdatedBy")
  contraceptive_history_updates PatientContraceptiveHistory[] @relation("PatientContraceptiveHistoryUpdatedBy")
  non_gyn_surgery_updates       PatientNonGynSurgery[]        @relation("PatientNonGynSurgeryUpdatedBy")

  @@unique([user_id, organization_id])
  @@index([organization_id, is_deleted])
  @@index([user_id, is_deleted])
  @@map("profiles")
}

model ProfileRole {
  id         String   @id @default(uuid()) @db.Uuid
  profile_id String   @db.Uuid
  role_id    String   @db.Uuid
  created_at DateTime @default(now())
  profile    Profile  @relation(fields: [profile_id], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [role_id], references: [id], onDelete: Cascade)

  @@unique([profile_id, role_id])
  @@index([role_id])
  @@map("profile_roles")
}

model ProfileBranch {
  id              String   @id @default(uuid()) @db.Uuid
  profile_id      String   @db.Uuid
  branch_id       String   @db.Uuid
  organization_id String   @db.Uuid
  created_at      DateTime @default(now())
  profile         Profile  @relation(fields: [profile_id], references: [id], onDelete: Cascade)
  branch          Branch   @relation(fields: [branch_id, organization_id], references: [id, organization_id], onDelete: Cascade)

  @@unique([profile_id, branch_id])
  @@index([organization_id, branch_id])
  @@map("profile_branches")
}

model Subscription {
  id                   String             @id @default(uuid()) @db.Uuid
  organization_id      String             @db.Uuid
  subscription_plan_id String             @db.Uuid
  status               SubscriptionStatus @default(TRIAL)
  starts_at            DateTime           @default(now())
  ends_at              DateTime?
  trial_ends_at        DateTime?
  created_at           DateTime           @default(now())
  updated_at           DateTime           @updatedAt
  is_deleted           Boolean            @default(false)
  deleted_at           DateTime?
  organization         Organization       @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  subscription_plan    SubscriptionPlan   @relation(fields: [subscription_plan_id], references: [id])

  @@index([organization_id, is_deleted])
  @@map("subscriptions")
}

model RefreshToken {
  id               String    @id @default(uuid()) @db.Uuid
  jti              String    @unique @db.Uuid
  token_hash       String
  user_id          String    @db.Uuid
  profile_id       String?   @db.Uuid
  organization_id  String?   @db.Uuid
  active_branch_id String?   @db.Uuid
  expires_at       DateTime
  is_revoked       Boolean   @default(false)
  revoked_at       DateTime?
  created_at       DateTime  @default(now())
  user             User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, is_revoked])
  @@map("refresh_tokens")
}

model VerificationCode {
  id           String              @id @default(uuid()) @db.Uuid
  user_id      String?             @db.Uuid
  channel      VerificationChannel
  purpose      VerificationPurpose
  target       String
  code_hash    String
  attempts     Int                 @default(0)
  max_attempts Int                 @default(5)
  is_resend    Boolean             @default(false)
  expires_at   DateTime
  consumed_at  DateTime?
  created_at   DateTime            @default(now())
  user         User?               @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([target, purpose, consumed_at])
  @@index([user_id, purpose])
  @@map("verification_codes")
}

model Invitation {
  id              String                  @id @default(uuid()) @db.Uuid
  organization_id String                  @db.Uuid
  invited_by_id   String                  @db.Uuid
  email           String
  first_name      String
  last_name       String
  phone_number    String?
  executive_title ExecutiveTitle?
  engagement_type EngagementType          @default(FULL_TIME)
  token_hash      String
  status          InvitationStatus        @default(PENDING)
  expires_at      DateTime
  accepted_at     DateTime?
  is_deleted      Boolean                 @default(false)
  deleted_at      DateTime?
  created_at      DateTime                @default(now())
  updated_at      DateTime                @updatedAt
  organization    Organization            @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  invited_by      User                    @relation("InvitedBy", fields: [invited_by_id], references: [id])
  roles           InvitationRole[]
  branches        InvitationBranch[]
  job_functions   InvitationJobFunction[]
  specialty_links InvitationSpecialty[]

  @@index([organization_id, status])
  @@index([email])
  @@index([expires_at])
  @@map("invitations")
}

model InvitationRole {
  id            String     @id @default(uuid()) @db.Uuid
  invitation_id String     @db.Uuid
  role_id       String     @db.Uuid
  created_at    DateTime   @default(now())
  invitation    Invitation @relation(fields: [invitation_id], references: [id], onDelete: Cascade)
  role          Role       @relation(fields: [role_id], references: [id], onDelete: Cascade)

  @@unique([invitation_id, role_id])
  @@map("invitation_roles")
}

model InvitationBranch {
  id              String     @id @default(uuid()) @db.Uuid
  invitation_id   String     @db.Uuid
  branch_id       String     @db.Uuid
  organization_id String     @db.Uuid
  created_at      DateTime   @default(now())
  invitation      Invitation @relation(fields: [invitation_id], references: [id], onDelete: Cascade)
  branch          Branch     @relation(fields: [branch_id, organization_id], references: [id, organization_id], onDelete: Cascade)

  @@unique([invitation_id, branch_id])
  @@index([organization_id, branch_id])
  @@map("invitation_branches")
}

model Notification {
  id          String    @id @default(uuid()) @db.Uuid
  user_id     String    @db.Uuid
  category    String
  title       String
  description String
  navigate_to String?
  is_read     Boolean   @default(false)
  read_at     DateTime?
  metadata    Json?
  is_deleted  Boolean   @default(false)
  deleted_at  DateTime?
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
  user        User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, is_read, is_deleted])
  @@index([user_id, category, is_deleted])
  @@map("notifications")
}

model WorkingSchedule {
  id         String       @id @default(uuid()) @db.Uuid
  profile_id String       @db.Uuid
  branch_id  String       @db.Uuid
  created_at DateTime     @default(now())
  updated_at DateTime     @updatedAt
  profile    Profile      @relation(fields: [profile_id], references: [id], onDelete: Cascade)
  branch     Branch       @relation(fields: [branch_id], references: [id], onDelete: Cascade)
  days       WorkingDay[]

  @@unique([profile_id, branch_id])
  @@index([profile_id])
  @@map("working_schedules")
}

model WorkingDay {
  id          String          @id @default(uuid()) @db.Uuid
  schedule_id String          @db.Uuid
  day_of_week DayOfWeek
  created_at  DateTime        @default(now())
  schedule    WorkingSchedule @relation(fields: [schedule_id], references: [id], onDelete: Cascade)
  shifts      WorkingShift[]

  @@unique([schedule_id, day_of_week])
  @@map("working_days")
}

model WorkingShift {
  id         String     @id @default(uuid()) @db.Uuid
  day_id     String     @db.Uuid
  start_time String
  end_time   String
  created_at DateTime   @default(now())
  day        WorkingDay @relation(fields: [day_id], references: [id], onDelete: Cascade)

  @@map("working_shifts")
}

model Specialty {
  id            String                  @id @default(uuid()) @db.Uuid
  name          String                  @unique
  code          String                  @unique
  description   String?
  templates     JourneyTemplate[]
  care_paths    CarePath[]
  procedures    Procedure[]
  profile_links ProfileSpecialty[]
  org_links     OrganizationSpecialty[]
  inv_links     InvitationSpecialty[]
  lab_tests     LabTest[]
  created_at    DateTime                @default(now())
  updated_at    DateTime                @updatedAt
  is_deleted    Boolean                 @default(false)
  deleted_at    DateTime?

  @@map("specialties")
}

model Procedure {
  id           String    @id @default(uuid()) @db.Uuid
  specialty_id String    @db.Uuid
  name         String
  code         String    @unique
  description  String?
  specialty    Specialty @relation(fields: [specialty_id], references: [id], onDelete: Cascade)
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt
  is_deleted   Boolean   @default(false)
  deleted_at   DateTime?

  @@index([specialty_id])
  @@map("procedures")
}

model ProfileSpecialty {
  id           String    @id @default(uuid()) @db.Uuid
  profile_id   String    @db.Uuid
  specialty_id String    @db.Uuid
  created_at   DateTime  @default(now())
  profile      Profile   @relation(fields: [profile_id], references: [id], onDelete: Cascade)
  specialty    Specialty @relation(fields: [specialty_id], references: [id], onDelete: Cascade)

  @@unique([profile_id, specialty_id])
  @@index([specialty_id])
  @@map("profile_specialties")
}

model OrganizationSpecialty {
  id              String       @id @default(uuid()) @db.Uuid
  organization_id String       @db.Uuid
  specialty_id    String       @db.Uuid
  created_at      DateTime     @default(now())
  organization    Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  specialty       Specialty    @relation(fields: [specialty_id], references: [id], onDelete: Cascade)

  @@unique([organization_id, specialty_id])
  @@index([specialty_id])
  @@map("organization_specialties")
}

model InvitationSpecialty {
  id            String     @id @default(uuid()) @db.Uuid
  invitation_id String     @db.Uuid
  specialty_id  String     @db.Uuid
  created_at    DateTime   @default(now())
  invitation    Invitation @relation(fields: [invitation_id], references: [id], onDelete: Cascade)
  specialty     Specialty  @relation(fields: [specialty_id], references: [id], onDelete: Cascade)

  @@unique([invitation_id, specialty_id])
  @@map("invitation_specialties")
}

model InvitationJobFunction {
  id              String      @id @default(uuid()) @db.Uuid
  invitation_id   String      @db.Uuid
  job_function_id String      @db.Uuid
  created_at      DateTime    @default(now())
  invitation      Invitation  @relation(fields: [invitation_id], references: [id], onDelete: Cascade)
  job_function    JobFunction @relation(fields: [job_function_id], references: [id], onDelete: Cascade)

  @@unique([invitation_id, job_function_id])
  @@map("invitation_job_functions")
}

model JourneyTemplate {
  id           String              @id @default(uuid()) @db.Uuid
  specialty_id String              @db.Uuid
  specialty    Specialty           @relation(fields: [specialty_id], references: [id], onDelete: Cascade)
  name         String              @unique
  type         JourneyTemplateType
  description  String?
  episodes     EpisodeTemplate[]
  journeys     PatientJourney[]
  created_at   DateTime            @default(now())
  updated_at   DateTime            @updatedAt
  is_deleted   Boolean             @default(false)
  deleted_at   DateTime?

  @@index([specialty_id])
  @@map("journey_templates")
}

model EpisodeTemplate {
  id                  String           @id @default(uuid()) @db.Uuid
  journey_template_id String           @db.Uuid
  journey_template    JourneyTemplate  @relation(fields: [journey_template_id], references: [id], onDelete: Cascade)
  name                String
  order               Int
  episodes            PatientEpisode[]
  created_at          DateTime         @default(now())
  updated_at          DateTime         @updatedAt
  is_deleted          Boolean          @default(false)
  deleted_at          DateTime?

  @@index([journey_template_id])
  @@map("episode_templates")
}

model Patient {
  id            String   @id @default(uuid()) @db.Uuid
  national_id   String   @unique
  full_name     String
  husband_name  String?
  date_of_birth DateTime @db.Date
  phone_number  String
  address       String

  // History tab snapshot fields (always patient-owned / global).
  // gynecological_baseline:    { age_at_menarche, cycle_regularity, duration, flow, dysmenorrhea }
  // gynecologic_procedures:    { items: string[], notes? }   (None/Cystectomy/Hysteroscopy/D&C/Laparoscopy/Other)
  // screening_history:         { pap_smear, pap_smear_date, mammography, mammography_date, vaccines: string[] }
  // obstetric_summary:         { gravida, para, abortion }   ← server-recomputed from PatientPregnancyHistory rows
  // medical_chronic_illnesses: { items: string[] }           (HTN/DM/Thyroid/Asthma/Other)
  // family_history:            { gynecologic_cancers: string[], chronic_illnesses: string[], genetic_disorders }
  // fertility_history:         { duration_of_infertility, partner_fertility_status, treatments: string[],
  //                              menstrual_ovulation_patterns, past_pregnancies_outcomes }
  // social_history:            { smoking?, alcohol?, occupation? }
  gynecological_baseline    Json?
  gynecologic_procedures    Json?
  screening_history         Json?
  obstetric_summary         Json?
  medical_chronic_illnesses Json?
  family_history            Json?
  fertility_history         Json?
  social_history            Json?

  journeys            PatientJourney[]
  allergies           PatientAllergy[]
  pregnancies         PatientPregnancyHistory[]
  contraceptives      PatientContraceptiveHistory[]
  non_gyn_surgeries   PatientNonGynSurgery[]
  current_medications PatientMedication[]
  history_notes       PatientHistoryNote[]
  guardian_links      PatientGuardian[]
  guardian_record     Guardian?                     @relation("PatientGuardianRecord")
  obgyn_history       PatientObgynHistory?

  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  is_deleted Boolean   @default(false)
  deleted_at DateTime?

  @@map("patients")
}

model PatientJourney {
  id                  String                  @id @default(uuid()) @db.Uuid
  patient_id          String                  @db.Uuid
  patient             Patient                 @relation(fields: [patient_id], references: [id], onDelete: Cascade)
  organization_id     String                  @db.Uuid
  organization        Organization            @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  journey_template_id String                  @db.Uuid
  journey_template    JourneyTemplate         @relation(fields: [journey_template_id], references: [id], onDelete: Cascade)
  care_path_id        String?                 @db.Uuid
  care_path           CarePath?               @relation(fields: [care_path_id], references: [id], onDelete: SetNull)
  created_by_id       String                  @db.Uuid
  created_by          Profile                 @relation(fields: [created_by_id], references: [id], onDelete: Cascade)
  status              JourneyStatus           @default(ACTIVE)
  started_at          DateTime                @default(now())
  ended_at            DateTime?
  episodes            PatientEpisode[]
  pregnancy_record    PregnancyJourneyRecord?
  created_at          DateTime                @default(now())
  updated_at          DateTime                @updatedAt
  is_deleted          Boolean                 @default(false)
  deleted_at          DateTime?

  @@index([patient_id, organization_id, is_deleted])
  @@index([organization_id, status, is_deleted])
  @@index([care_path_id])
  @@map("patient_journeys")
}

model PatientEpisode {
  id                   String                  @id @default(uuid()) @db.Uuid
  journey_id           String                  @db.Uuid
  journey              PatientJourney          @relation(fields: [journey_id], references: [id], onDelete: Cascade)
  episode_template_id  String                  @db.Uuid
  episode_template     EpisodeTemplate         @relation(fields: [episode_template_id], references: [id], onDelete: Cascade)
  care_path_episode_id String?                 @db.Uuid
  care_path_episode    CarePathEpisode?        @relation(fields: [care_path_episode_id], references: [id], onDelete: SetNull)
  name                 String
  order                Int
  status               EpisodeStatus           @default(PENDING)
  started_at           DateTime?
  ended_at             DateTime?
  visits               Visit[]
  pregnancy_record     PregnancyEpisodeRecord?
  created_at           DateTime                @default(now())
  updated_at           DateTime                @updatedAt
  is_deleted           Boolean                 @default(false)
  deleted_at           DateTime?

