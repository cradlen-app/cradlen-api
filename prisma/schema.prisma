  id              String                 @id @default(uuid()) @db.Uuid
  organization_id String                 @db.Uuid
  organization    Organization           @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  full_name       String
  national_id     String?
  phone_number    String?
  email           String?
  company_name    String
  specialty_focus String?
  notes           String?
  is_deleted      Boolean                @default(false)
  deleted_at      DateTime?
  created_at      DateTime               @default(now())
  updated_at      DateTime               @updatedAt
  medications     MedicalRepMedication[]
  visits          MedicalRepVisit[]

  @@unique([organization_id, national_id])
  @@index([organization_id, company_name])
  @@index([organization_id, is_deleted])
  @@map("medical_reps")
}

model MedicalRepMedication {
  id             String     @id @default(uuid()) @db.Uuid
  medical_rep_id String     @db.Uuid
  medical_rep    MedicalRep @relation(fields: [medical_rep_id], references: [id], onDelete: Cascade)
  medication_id  String     @db.Uuid
  medication     Medication @relation(fields: [medication_id], references: [id], onDelete: Cascade)
  created_at     DateTime   @default(now())

  @@unique([medical_rep_id, medication_id])
  @@map("medical_rep_medications")
}

model MedicalRepVisit {
  id                 String                      @id @default(uuid()) @db.Uuid
  medical_rep_id     String                      @db.Uuid
  medical_rep        MedicalRep                  @relation(fields: [medical_rep_id], references: [id], onDelete: Cascade)
  organization_id    String                      @db.Uuid
  organization       Organization                @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  branch_id          String                      @db.Uuid
  branch             Branch                      @relation(fields: [branch_id], references: [id], onDelete: Cascade)
  assigned_doctor_id String                      @db.Uuid
  assigned_doctor    Profile                     @relation("MedRepVisitDoctor", fields: [assigned_doctor_id], references: [id], onDelete: Cascade)
  created_by_id      String                      @db.Uuid
  created_by         Profile                     @relation("MedRepVisitCreatedBy", fields: [created_by_id], references: [id], onDelete: Cascade)
  scheduled_at       DateTime
  status             MedicalRepVisitStatus       @default(SCHEDULED)
  priority           VisitPriority               @default(NORMAL)
  queue_number       Int?
  // Visit-encounter (examination) fields — see the rep-visit examination surface.
  purpose            MedicalRepVisitPurpose?
  samples_received   Boolean                     @default(false)
  outcome            MedicalRepVisitOutcome?
  follow_up_date     DateTime?
  // Optimistic/cache token for the examination GET/PATCH (mirrors Visit.examination_version).
  examination_version Int                        @default(1)
  notes              String?
  // Audit anchor (see Visit.form_template_id).
  form_template_id   String?                     @db.Uuid
  form_template      FormTemplate?               @relation("MedicalRepVisitFormTemplate", fields: [form_template_id], references: [id], onDelete: SetNull)
  checked_in_at      DateTime?
  started_at         DateTime?
  completed_at       DateTime?
  is_deleted         Boolean                     @default(false)
  deleted_at         DateTime?
  created_at         DateTime                    @default(now())
  updated_at         DateTime                    @updatedAt
  medications        MedicalRepVisitMedication[]

  @@index([organization_id, branch_id, scheduled_at])
  @@index([assigned_doctor_id, status, is_deleted])
  @@index([branch_id, status, scheduled_at])
  @@map("medical_rep_visits")
}

model MedicalRepVisitMedication {
  id                   String          @id @default(uuid()) @db.Uuid
  medical_rep_visit_id String          @db.Uuid
  medical_rep_visit    MedicalRepVisit @relation(fields: [medical_rep_visit_id], references: [id], onDelete: Cascade)
  medication_id        String          @db.Uuid
  medication           Medication      @relation(fields: [medication_id], references: [id], onDelete: Cascade)
  discussion_notes     String?

  @@unique([medical_rep_visit_id, medication_id])
  @@map("medical_rep_visit_medications")
}

enum CalendarEventType {
  DAY_OFF
  PROCEDURE
  MEETING
  GENERIC
}

enum CalendarVisibility {
  PRIVATE
  ORGANIZATION
}

model CalendarEvent {
  id              String  @id @default(uuid()) @db.Uuid
  profile_id      String  @db.Uuid
  organization_id String  @db.Uuid
  branch_id       String? @db.Uuid

  event_type  CalendarEventType
  visibility  CalendarVisibility @default(PRIVATE)
  title       String
  description String?

  start_at DateTime
  end_at   DateTime
  all_day  Boolean  @default(false)

  procedure_id String? @db.Uuid
  patient_id   String? @db.Uuid

  is_deleted Boolean   @default(false)
  deleted_at DateTime?
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt

  profile      Profile                  @relation("CalendarEventProfile", fields: [profile_id], references: [id], onDelete: Cascade)
  organization Organization             @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  branch       Branch?                  @relation(fields: [branch_id], references: [id], onDelete: SetNull)
  procedure    Procedure?               @relation(fields: [procedure_id], references: [id], onDelete: SetNull)
  patient      Patient?                 @relation(fields: [patient_id], references: [id], onDelete: SetNull)
  assistants   CalendarEventAssistant[]

  @@index([profile_id, start_at, end_at])
  @@index([organization_id, branch_id, start_at])
  @@index([organization_id, visibility, start_at])
  // CHECK (end_at > start_at) constraint `calendar_events_range_chk` added
  // via raw SQL in the `calendar_event_constraints` migration.
  @@map("calendar_events")
}

model CalendarEventAssistant {
  id                String   @id @default(uuid()) @db.Uuid
  calendar_event_id String   @db.Uuid
  profile_id        String   @db.Uuid
  created_at        DateTime @default(now())

  event   CalendarEvent @relation(fields: [calendar_event_id], references: [id], onDelete: Cascade)
  profile Profile       @relation("CalendarEventAssistantProfile", fields: [profile_id], references: [id], onDelete: Cascade)

  @@unique([calendar_event_id, profile_id])
  @@index([profile_id])
  @@map("calendar_event_assistants")
}

model PatientOrgEnrollment {
  id              String                     @id @default(uuid()) @db.Uuid
  patient_id      String                     @db.Uuid
  organization_id String                     @db.Uuid
  status          PatientOrgEnrollmentStatus @default(PENDING)
  created_at      DateTime                   @default(now())
  updated_at      DateTime                   @updatedAt
  activated_at    DateTime?
  is_deleted      Boolean                    @default(false)
  deleted_at      DateTime?

  patient      Patient      @relation(fields: [patient_id], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@index([patient_id, organization_id, is_deleted])
  @@map("patient_org_enrollments")
}

// ============================================================================
// Financial module — services, price lists, invoices, payments
// ============================================================================

model Service {
  id              String      @id @default(uuid()) @db.Uuid
  organization_id String?     @db.Uuid
  code            String
  name            String
  description     String?
  service_type    ServiceType
  is_active       Boolean     @default(true)
  is_deleted      Boolean     @default(false)
  deleted_at      DateTime?
  created_by_id   String      @db.Uuid
  created_at      DateTime    @default(now())
  updated_at      DateTime    @updatedAt

  organization       Organization?           @relation("OrgServices", fields: [organization_id], references: [id])
  created_by         Profile                 @relation("ServiceCreatedBy", fields: [created_by_id], references: [id])
  specialties        ServiceSpecialty[]
  price_list_items   PriceListItem[]
  provider_services  ProviderService[]
  provider_overrides ProviderPriceOverride[]
  invoice_items      InvoiceItem[]

  @@unique([organization_id, code])
  @@index([organization_id, is_active, is_deleted])
  @@map("services")
}

model ServiceSpecialty {
  service_id   String @db.Uuid
  specialty_id String @db.Uuid

  service   Service   @relation(fields: [service_id], references: [id], onDelete: Cascade)
  specialty Specialty @relation("SpecialtyServices", fields: [specialty_id], references: [id])

  @@id([service_id, specialty_id])
  @@map("service_specialties")
}

model PriceList {
  id              String    @id @default(uuid()) @db.Uuid
  organization_id String    @db.Uuid
  branch_id       String?   @db.Uuid
  name            String
  currency        String    @default("EGP")
  is_default      Boolean   @default(false)
  valid_from      DateTime?
  valid_to        DateTime?
  is_active       Boolean   @default(true)
  is_deleted      Boolean   @default(false)
  deleted_at      DateTime?
  created_by_id   String?   @db.Uuid
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  organization Organization    @relation("OrgPriceLists", fields: [organization_id], references: [id])
  branch       Branch?         @relation("BranchPriceLists", fields: [branch_id], references: [id])
  created_by   Profile?        @relation("PriceListCreatedBy", fields: [created_by_id], references: [id], onDelete: SetNull)
  items        PriceListItem[]

  @@index([organization_id, branch_id, is_default, is_active, is_deleted])
  @@map("price_lists")
}

model PriceListItem {
  id            String    @id @default(uuid()) @db.Uuid
  price_list_id String    @db.Uuid
  service_id    String    @db.Uuid
  unit_price    Decimal   @db.Decimal(10, 2)
  is_active     Boolean   @default(true)
  is_deleted    Boolean   @default(false)
  deleted_at    DateTime?
  created_by_id String?   @db.Uuid
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  price_list PriceList @relation(fields: [price_list_id], references: [id], onDelete: Cascade)
  service    Service   @relation(fields: [service_id], references: [id])
  created_by Profile?  @relation("PriceListItemCreatedBy", fields: [created_by_id], references: [id], onDelete: SetNull)

  @@unique([price_list_id, service_id])
  @@map("price_list_items")
}

model ProviderService {
  id               String    @id @default(uuid()) @db.Uuid
  profile_id       String    @db.Uuid
  service_id       String    @db.Uuid
  organization_id  String    @db.Uuid
  branch_id        String?   @db.Uuid
  duration_minutes Int?
  is_active        Boolean   @default(true)
  is_deleted       Boolean   @default(false)
  deleted_at       DateTime?
  created_by_id    String?   @db.Uuid
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt

  profile      Profile      @relation("ProfileProviderServices", fields: [profile_id], references: [id])
  service      Service      @relation(fields: [service_id], references: [id])
  organization Organization @relation("OrgProviderServices", fields: [organization_id], references: [id])
  branch       Branch?      @relation("BranchProviderServices", fields: [branch_id], references: [id])
  created_by   Profile?     @relation("ProviderServiceCreatedBy", fields: [created_by_id], references: [id], onDelete: SetNull)

  @@unique([profile_id, service_id, organization_id, branch_id])
  @@index([profile_id, organization_id, is_active, is_deleted])
  @@map("provider_services")
}

model ProviderPriceOverride {
  id              String    @id @default(uuid()) @db.Uuid
  profile_id      String    @db.Uuid
  service_id      String    @db.Uuid
  organization_id String    @db.Uuid
  branch_id       String?   @db.Uuid
  price           Decimal   @db.Decimal(10, 2)
  currency        String    @default("EGP")
  valid_from      DateTime?
  valid_to        DateTime?
  is_active       Boolean   @default(true)
  is_deleted      Boolean   @default(false)
  deleted_at      DateTime?
  created_by_id   String?   @db.Uuid
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  profile      Profile      @relation("ProfilePriceOverrides", fields: [profile_id], references: [id])
  service      Service      @relation(fields: [service_id], references: [id])
  organization Organization @relation("OrgPriceOverrides", fields: [organization_id], references: [id])
  branch       Branch?      @relation("BranchPriceOverrides", fields: [branch_id], references: [id])
  created_by   Profile?     @relation("ProviderPriceOverrideCreatedBy", fields: [created_by_id], references: [id], onDelete: SetNull)

  @@index([profile_id, service_id, organization_id, is_active, is_deleted])
  @@map("provider_price_overrides")
}

model InvoiceSequence {
  id              String    @id @default(uuid()) @db.Uuid
  organization_id String    @db.Uuid
  year            Int
  last_seq        Int       @default(0)
  is_deleted      Boolean   @default(false)
  deleted_at      DateTime?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  organization Organization @relation("OrgInvoiceSequences", fields: [organization_id], references: [id])

  @@unique([organization_id, year])
  @@map("invoice_sequences")
}

model Invoice {
  id                 String        @id @default(uuid()) @db.Uuid
  invoice_number     String
  invoice_type       InvoiceType   @default(STANDARD)
  organization_id    String        @db.Uuid
  branch_id          String        @db.Uuid
  patient_id         String        @db.Uuid
  visit_id           String?       @db.Uuid
  assigned_doctor_id String?       @db.Uuid
  status             InvoiceStatus @default(DRAFT)
  subtotal           Decimal       @default(0) @db.Decimal(10, 2)
  discount_amount    Decimal       @default(0) @db.Decimal(10, 2)
  tax_amount         Decimal       @default(0) @db.Decimal(10, 2)
  total_amount       Decimal       @default(0) @db.Decimal(10, 2)
  paid_amount        Decimal       @default(0) @db.Decimal(10, 2)
  currency           String        @default("EGP")
  notes              String?
  issued_at          DateTime?
  due_date           DateTime?
  created_by_id      String        @db.Uuid
  is_deleted         Boolean       @default(false)
  deleted_at         DateTime?
  created_at         DateTime      @default(now())
  updated_at         DateTime      @updatedAt

  organization    Organization           @relation("OrgInvoices", fields: [organization_id], references: [id])
  branch          Branch                 @relation("BranchInvoices", fields: [branch_id], references: [id])
  patient         Patient                @relation("PatientInvoices", fields: [patient_id], references: [id])
  visit           Visit?                 @relation("VisitInvoices", fields: [visit_id], references: [id])
  assigned_doctor Profile?               @relation("InvoiceDoctor", fields: [assigned_doctor_id], references: [id])
  created_by      Profile                @relation("InvoiceCreatedBy", fields: [created_by_id], references: [id])
  items           InvoiceItem[]
  payments        Payment[]
  insurance_claim InvoiceInsuranceClaim?

  @@unique([organization_id, invoice_number])
  @@index([organization_id, branch_id, status, is_deleted])
  @@index([patient_id, is_deleted])
  @@map("invoices")
}

model InvoiceItem {
  id              String        @id @default(uuid()) @db.Uuid
  invoice_id      String        @db.Uuid
  service_id      String?       @db.Uuid
  description     String
  quantity        Int           @default(1)
  unit_price      Decimal       @db.Decimal(10, 2)
  currency        String        @default("EGP")
  discount_amount Decimal       @default(0) @db.Decimal(10, 2)
  total_amount    Decimal       @db.Decimal(10, 2)
  pricing_source  PricingSource @default(CUSTOM)
  created_at      DateTime      @default(now())
  updated_at      DateTime      @updatedAt

  invoice Invoice  @relation(fields: [invoice_id], references: [id], onDelete: Cascade)
  service Service? @relation(fields: [service_id], references: [id])

  @@index([invoice_id])
  @@map("invoice_items")
}

model Payment {
  id               String        @id @default(uuid()) @db.Uuid
  invoice_id       String        @db.Uuid
  amount           Decimal       @db.Decimal(10, 2)
  currency         String        @default("EGP")
  status           PaymentStatus @default(COMPLETED)
  payment_method   PaymentMethod
  payment_date     DateTime
  reference_number String?
  notes            String?
  recorded_by_id   String        @db.Uuid
  is_deleted       Boolean       @default(false)
  deleted_at       DateTime?
  created_at       DateTime      @default(now())
  updated_at       DateTime      @updatedAt

  invoice     Invoice  @relation(fields: [invoice_id], references: [id])
  recorded_by Profile  @relation("PaymentRecordedBy", fields: [recorded_by_id], references: [id])
  refunds     Refund[]

  @@index([invoice_id, is_deleted])
  @@map("payments")
}

model Refund {
  id             String       @id @default(uuid()) @db.Uuid
  payment_id     String       @db.Uuid
  amount         Decimal      @db.Decimal(10, 2)
  reason         String
  status         RefundStatus @default(COMPLETED)
  refunded_by_id String       @db.Uuid
  refunded_at    DateTime     @default(now())
  is_deleted     Boolean      @default(false)
  deleted_at     DateTime?
  created_at     DateTime     @default(now())
  updated_at     DateTime     @updatedAt

  payment     Payment @relation(fields: [payment_id], references: [id])
  refunded_by Profile @relation("RefundedBy", fields: [refunded_by_id], references: [id])

  @@map("refunds")
}

model InvoiceInsuranceClaim {
  id             String               @id @default(uuid()) @db.Uuid
  invoice_id     String               @unique @db.Uuid
  policy_number  String
  covered_amount Decimal              @db.Decimal(10, 2)
  patient_copay  Decimal              @db.Decimal(10, 2)
  status         InsuranceClaimStatus @default(PENDING)
  created_at     DateTime             @default(now())
  updated_at     DateTime             @updatedAt

  is_deleted Boolean   @default(false)
  deleted_at DateTime?

  invoice Invoice @relation(fields: [invoice_id], references: [id])

  @@map("invoice_insurance_claims")
}
